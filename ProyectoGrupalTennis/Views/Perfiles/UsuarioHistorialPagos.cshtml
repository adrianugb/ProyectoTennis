@model ProyectoGrupalTennis.Models.UsuarioHistorialPagosViewModel

@{
    ViewData["Title"] = "Historial de Pagos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Historial de Pagos</h1>
                    <p class="perfil-subtitle">
                        Consulta los pagos registrados y el estado de tus comprobantes.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-credit-card"></i>
                    Pagos del Usuario
                </div>
            </div>

            <div class="mb-3">
                <a asp-controller="Home" asp-action="PerfilUsuario" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-arrow-left me-1"></i> Regresar
                </a>
            </div>

            <form asp-action="HistorialPagos" method="get" class="perfil-filter-row">
                <input type="text"
                       name="buscar"
                       value="@Model.FiltroBuscar"
                       class="form-control"
                       placeholder="Buscar por concepto o método..." />

                <select name="estado" class="form-select">
                    <option value="">Todos los estados</option>
                    <option value="Pendiente" selected="@(Model.FiltroEstado == "Pendiente")">Pendiente</option>
                    <option value="Pagado" selected="@(Model.FiltroEstado == "Pagado")">Pagado</option>
                    <option value="Rechazado" selected="@(Model.FiltroEstado == "Rechazado")">Rechazado</option>
                    <option value="En revisión" selected="@(Model.FiltroEstado == "En revisión")">En revisión</option>
                </select>

                <select name="factura" class="form-select">
                    <option value="">Todas las facturas</option>

                    <option value="Disponible"
                            selected="@(Model.FiltroFactura == "Disponible")">
                        Disponible
                    </option>

                    <option value="Pendiente"
                            selected="@(Model.FiltroFactura == "Pendiente")">
                        En proceso
                    </option>

                    <option value="No disponible"
                            selected="@(Model.FiltroFactura == "No disponible")">
                        No disponible
                    </option>
                </select>


                <button class="btn btn-primary" type="submit">
                    <i class="fa fa-search"></i> Buscar
                </button>
            </form>

            <div class="table-responsive">
                <table class="perfil-table">
                    <thead>
                        <tr>
                            <th>Concepto</th>
                            <th>Método</th>
                            <th>Monto</th>
                            <th>Fecha de pago</th>
                            <th>Estado del pago</th>
                            <th>Factura</th>
                            <th>Fecha factura</th>
                            <th>Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Pagos.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center">
                                    No hay pagos registrados.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var pago in Model.Pagos)
                            {
                                <tr>
                                    <td>@pago.Concepto</td>
                                    <td>@pago.MetodoPago</td>
                                    <td>₡@pago.Monto.ToString("N0")</td>
                                    <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>

                                    <td>@pago.Estado</td>

                                    <td>
                                        @if (pago.NumeroFactura != null)
                                        {
                                            <span class="perfil-badge-success">Disponible</span>
                                        }
                                        else if (pago.Estado == "Pagado")
                                        {
                                            <span class="perfil-badge-warning">Pendiente</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No disponible</span>
                                        }
                                    </td>

                                    <td>
                                        @(pago.FechaFactura.HasValue
                                            ? pago.FechaFactura.Value.ToString("dd/MM/yyyy")
                                            : "—")
                                    </td>
                                    <td>
                                        @if (pago.Estado == "Pendiente" || pago.Estado == "Rechazado")
                                        {
                                            <form asp-action="SubirComprobante"
                                                  method="post"
                                                  enctype="multipart/form-data">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="idPago" value="@pago.IdPago" />

                                                <input type="file"
                                                       name="comprobante"
                                                       class="form-control mb-2"
                                                       accept=".jpg,.jpeg,.png,.pdf"
                                                       required />

                                                <button type="submit" class="btn btn-success btn-sm">
                                                    @(pago.Estado == "Pendiente"
                                                        ? "Adjuntar comprobante"
                                                        : "Volver a subir comprobante")
                                                </button>

                                            </form>
                                        }
                                        else if (pago.Estado == "En revisión")
                                        {
                                            <span class="perfil-badge-warning">
                                                En revisión
                                            </span>

                                            <br />

                                            <small class="text-muted">
                                                Esperando validación del administrador.
                                            </small>
                                        }
                                        else if (pago.NumeroFactura != null)
                                        {
                                            <a asp-action="DescargarComprobante"
                                               asp-route-idPago="@pago.IdPago"
                                               class="perfil-action-link">
                                                Descargar factura
                                            </a>
                                        }
                                        else if (pago.Estado == "Pagado")
                                        {
                                            <span class="perfil-badge-success">
                                                Pago confirmado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                No disponible
                                            </span>
                                        }
                                    </td>
                                   
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</section>