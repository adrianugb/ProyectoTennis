@model ProyectoGrupalTennis.Models.AdminHistorialPagosViewModel

@{
    ViewData["Title"] = "Gestión de Pagos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Pagos</h1>
                    <p class="perfil-subtitle">
                        Consulte el historial general de pagos registrados en el sistema.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-money"></i> Pagos Administrativos
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Historial general de pagos</h2>

                    <div class="perfil-actions">
                        <a asp-controller="Home" asp-action="AdminFacturacion" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                    </div>
                </div>

                <form asp-action="AdminPagos" method="get">

                    <div class="perfil-filter-row">
                        <input type="text"
                               name="buscar"
                               value="@Model.FiltroBuscar"
                               class="form-control"
                               placeholder="Buscar por alumno o concepto..." />
                    </div>

                    <div class="perfil-filter-row">

                        <select name="estado" class="form-select">
                            <option value="">Todos los estados</option>
                            <option value="Pendiente" selected="@(Model.FiltroEstado == "Pendiente")">Pendiente</option>
                            <option value="Pagado" selected="@(Model.FiltroEstado == "Pagado")">Pagado</option>
                            <option value="Anulado" selected="@(Model.FiltroEstado == "Anulado")">Anulado</option>
                            <option value="Rechazado" selected="@(Model.FiltroEstado == "Rechazado")">Rechazado</option>
                        </select>

                        <select name="factura" class="form-select">
                            <option value="">Todas las facturas</option>
                            <option value="Disponible" selected="@(Model.FiltroFactura == "Disponible")">Disponible</option>
                            <option value="Pendiente" selected="@(Model.FiltroFactura == "Pendiente")">Pendiente</option>
                            <option value="No disponible" selected="@(Model.FiltroFactura == "No disponible")">No disponible</option>
                        </select>

                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label class="form-label">Desde</label>
                            <input type="date"
                                   name="fechaDesde"
                                   value="@(Model.FechaDesde?.ToString("yyyy-MM-dd"))"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Hasta</label>
                            <input type="date"
                                   name="fechaHasta"
                                   value="@(Model.FechaHasta?.ToString("yyyy-MM-dd"))"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="perfil-filter-row mt-3">
                        <button class="btn btn-primary" type="submit">
                            <i class="fa fa-search"></i> Buscar
                        </button>

                        <a asp-action="AdminPagos" class="btn btn-outline-secondary">
                            Limpiar
                        </a>
                    </div>

                </form>
                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Alumno</th>
                                <th>Concepto</th>
                                <th>Método</th>
                                <th>Monto</th>
                                <th>Fecha de pago</th>
                                <th>Estado del pago</th>
                                <th>Factura</th>
                                <th>Fecha factura</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (!Model.Pagos.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center">
                                        No hay pagos registrados.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var pago in Model.Pagos)
                                {
                                    <tr>
                                        <td>PAG-@pago.IdPago</td>
                                        <td>@pago.Alumno</td>
                                        <td>@pago.Concepto</td>
                                        <td>@pago.MetodoPago</td>
                                        <td>₡@pago.Monto.ToString("N0")</td>
                                        <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                        <td>@pago.Estado</td>

                                        <td>
                                            @if (pago.FacturaEstado == "Disponible")
                                            {
                                                <span class="perfil-badge-success">Disponible</span>
                                            }
                                            else if (pago.FacturaEstado == "Pendiente")
                                            {
                                                <span class="perfil-badge-warning">En proceso</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No disponible</span>
                                            }
                                        </td>

                                        <td>
                                            @(pago.FechaFactura.HasValue
                                                ? pago.FechaFactura.Value.ToString("dd/MM/yyyy")
                                                : "—")
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

            </div>

        </div>
    </div>
</section>