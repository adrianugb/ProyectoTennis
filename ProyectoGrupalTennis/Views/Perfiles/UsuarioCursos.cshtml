@model ProyectoGrupalTennis.Models.UsuarioCursosViewModel
@{
    ViewData["Title"] = "Cursos Disponibles";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Cursos Disponibles</h1>
                    <p class="perfil-subtitle">
                        Explorá los cursos activos de la academia, sus niveles, horarios y profesores.
                    </p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-book-open"></i> Catálogo de Cursos
                </div>
            </div>

            @* Botón volver al panel *@
            <div class="mb-3">
                <a asp-controller="Home" asp-action="PerfilUsuario" class="btn-volver">
                    <i class="fa fa-arrow-left"></i> Volver al Perfil
                </a>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de cursos</h2>
                </div>

                <form method="get" asp-controller="Usuario" asp-action="MisCursos">
                    <div class="perfil-filter-row">
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar curso..."
                               value="@Model.FiltroBuscar" />

                        <select name="nivel" class="form-select">
                            <option value="">Filtrar por nivel</option>
                            @{
                                var niveles = new[] { "Básico", "Intermedio", "Avanzado" };
                                foreach (var n in niveles)
                                {
                                    if (Model.FiltroNivel == n)
                                    {
                                        <option value="@n" selected>@n</option>
                                    }
                                    else
                                    {
                                        <option value="@n">@n</option>
                                    }
                                }
                            }
                        </select>

                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search me-1"></i> Buscar
                        </button>

                        @if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar) || !string.IsNullOrWhiteSpace(Model.FiltroNivel))
                        {
                            <a asp-controller="Usuario" asp-action="MisCursos" class="btn btn-secondary">
                                <i class="fa fa-times me-1"></i> Limpiar
                            </a>
                        }
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table" id="tablaCursos">
                        <thead>
                            <tr>
                                <th>Curso</th>
                                <th>Nivel</th>
                                <th>Horarios</th>
                                <th>Profesor</th>
                                <th>Cupos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Cursos.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="fa fa-book fa-2x mb-2 d-block"></i>
                                        @if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar) || !string.IsNullOrWhiteSpace(Model.FiltroNivel))
                                        {
                                            <span>No se encontraron cursos con los criterios indicados.</span>
                                        }
                                        else
                                        {
                                            <span>No hay cursos disponibles en este momento.</span>
                                        }
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var curso in Model.Cursos)
                                {
                                    <tr>
                                        <td>
                                            <strong>@curso.Nombre</strong>
                                            @if (!string.IsNullOrWhiteSpace(curso.Descripcion))
                                            {
                                                <br /><small class="text-muted">@curso.Descripcion</small>
                                            }
                                        </td>
                                        <td>@curso.Nivel</td>
                                        <td>
                                            @if (curso.Horarios.Any())
                                            {
                                                @foreach (var h in curso.Horarios)
                                                {
                                                    <small class="d-block">@h</small>
                                                }
                                            }
                                            else
                                            {
                                                <small class="text-muted">Sin horario asignado</small>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(curso.NombreProfesor) && curso.NombreProfesor != "Sin asignar")
                                            {
                                                <span><i class="fa fa-chalkboard-teacher me-1"></i>@curso.NombreProfesor</span>
                                            }
                                            else
                                            {
                                                <small class="text-muted">Sin asignar</small>
                                            }
                                        </td>
                                        <td>
                                            @if (curso.CuposDisponibles > 0)
                                            {
                                                <span class="perfil-badge-success">@curso.CuposDisponibles disponibles</span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-warning">Sin cupos</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>