@{
    ViewData["Title"] = "Administración de Usuarios";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Usuarios</h1>
                    <p class="perfil-subtitle">
                        Administra las cuentas del sistema, roles y estados de los usuarios.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-users"></i> Administración de Usuarios
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de usuarios</h2>

                    <div class="perfil-actions">
                        <a asp-controller="Home" asp-action="PerfilAdmin" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>

                        <a href="#" class="perfil-btn">
                            <i class="fa fa-plus"></i> Agregar usuario
                        </a>
                    </div>
                </div>

                <div class="perfil-filter-row">
                    <input type="text" class="form-control" placeholder="Buscar por nombre o correo..." />

                    <select class="form-select">
                        <option>Filtrar por rol</option>
                        <option>Administrador</option>
                        <option>Usuario</option>
                        <option>Profesor</option>
                    </select>

                    <select class="form-select">
                        <option>Filtrar por estado</option>
                        <option>Activo</option>
                        <option>Inactivo</option>
                    </select>
                </div>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td>USR-001</td>
                                <td>Fabiola Zamora</td>
                                <td>fabi@email.com</td>
                                <td>Administrador</td>
                                <td><span class="perfil-badge-success">Activo</span></td>
                                <td>
                                    <a href="#" class="perfil-action-link">Editar</a>
                                    <span class="perfil-action-separator">|</span>
                                    <a href="#" class="perfil-action-link">Desactivar</a>
                                    <span class="perfil-action-separator">|</span>
                                    <a href="#" class="perfil-action-link">Ver</a>
                                </td>
                            </tr>

                            <tr>
                                <td>USR-002</td>
                                <td>Juan Pérez</td>
                                <td>juan@email.com</td>
                                <td>Usuario</td>
                                <td><span class="perfil-badge-success">Activo</span></td>
                                <td>
                                    <a href="#" class="perfil-action-link">Editar</a>
                                    <span class="perfil-action-separator">|</span>
                                    <a href="#" class="perfil-action-link">Desactivar</a>
                                    <span class="perfil-action-separator">|</span>
                                    <a href="#" class="perfil-action-link">Ver</a>
                                </td>
                            </tr>

                            <tr>
                                <td>USR-003</td>
                                <td>Andrea Solano</td>
                                <td>andrea@email.com</td>
                                <td>Profesor</td>
                                <td><span class="perfil-badge-warning">Inactivo</span></td>
                                <td>
                                    <a href="#" class="perfil-action-link">Editar</a>
                                    <span class="perfil-action-separator">|</span>
                                    <a href="#" class="perfil-action-link">Activar</a>
                                    <span class="perfil-action-separator">|</span>
                                    <a href="#" class="perfil-action-link">Ver</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</section>