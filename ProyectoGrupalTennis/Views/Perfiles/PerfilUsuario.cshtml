@{
    ViewData["Title"] = "Perfil de Usuario";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Perfil de Usuario</h1>
                    <p class="perfil-subtitle">
                        Resumen de tu cuenta, progreso, próximas clases y opciones rápidas.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-user"></i> Cuenta
                </div>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="perfil-table-block">
                        <div class="perfil-table-header">
                            <h2 class="perfil-table-title">Información básica</h2>

                            <a href="#" class="perfil-btn-outline">
                                <i class="fa fa-edit"></i> Editar perfil
                            </a>
                        </div>

                        <div class="row" style="margin-top:12px;">
                            <div class="col-sm-4">
                                <img src="~/images/author-image.jpg" class="img-responsive" style="width:100%; border-radius:12px;" alt="Usuario" />
                            </div>
                            <div class="col-sm-8">
                                <p><strong>Nombre:</strong> María González</p>
                                <p><strong>Correo:</strong> maria.gonzalez@email.com</p>
                                <p><strong>Teléfono:</strong> 8888-1111</p>
                                <p><strong>Nivel:</strong> Intermedio</p>
                                <p><strong>Matrícula:</strong> ACT-2024-045</p>
                            </div>
                        </div>
                    </div>

                    <div class="perfil-table-block">
                        <div class="perfil-table-header">
                            <h2 class="perfil-table-title">Próximas clases</h2>

                            <a href="/Home/Matricula" class="perfil-btn">
                                Ver agenda
                            </a>
                        </div>

                        <div class="table-responsive">
                            <table class="perfil-table">
                                <thead>
                                    <tr>
                                        <th>Clase</th>
                                        <th>Fecha</th>
                                        <th>Hora</th>
                                        <th>Profesor</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Técnica - Drives</td>
                                        <td>2026-04-22</td>
                                        <td>17:00</td>
                                        <td>Mario Muñoz</td>
                                        <td><span class="perfil-badge-success">Confirmada</span></td>
                                    </tr>
                                    <tr>
                                        <td>Entrenamiento físico</td>
                                        <td>2026-04-24</td>
                                        <td>18:30</td>
                                        <td>Andrea Solano</td>
                                        <td><span class="perfil-badge-info">Pendiente</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>

                <div class="col-md-4">
                    <div class="perfil-card" style="text-align:left;">
                        <i class="fa fa-trophy"></i>
                        <h3>Progreso</h3>
                        <p>Seguimiento técnico y metas alcanzadas.</p>

                        <div style="margin-top:12px;">
                            <div><strong>Asistencia mensual:</strong> 87%</div>
                            <div><strong>Objetivo actual:</strong> Mejorar precisión en drives</div>
                            <div style="margin-top:10px;">
                                <div class="perfil-summary-item" style="padding:10px;">
                                    <strong>Nivel actual</strong>
                                    <span>Intermedio</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="perfil-card" style="margin-top:16px; text-align:left;">
                        <i class="fa fa-wallet"></i>
                        <h3>Pagos y suscripciones</h3>
                        <p>Estado de suscripción y recibos recientes.</p>

                        <div style="margin-top:12px;">
                            <p><strong>Plan:</strong> Mensual</p>
                            <p><strong>Último pago:</strong> 2026-04-01 • ₡45,000</p>
                            <a href="#" class="perfil-btn" style="margin-top:6px;">Ver recibos</a>
                        </div>
                    </div>

                    <div class="perfil-card" style="margin-top:16px; text-align:left;">
                        <i class="fa fa-headset"></i>
                        <h3>Soporte</h3>
                        <p>¿Necesitas ayuda?</p>
                        <div class="module-actions" style="margin-top:10px;">
                            <a href="/Home/Contacto" class="perfil-btn-outline">Contactar soporte</a>
                        </div>
                    </div>

                    <div class="perfil-card" style="margin-top:16px; text-align:left;">
                        <i class="fa fa-trophy"></i>
                        <h3>Campeonatos e Inscripciones</h3>
                        <p>Ver torneos disponibles e inscribirte como jugador (vista mockup).</p>
                        <div style="margin-top:12px;">
                            <a asp-controller="Home" asp-action="Campeonatos" class="perfil-btn">Ir a Campeonatos</a>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>
