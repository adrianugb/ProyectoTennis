@{
    ViewData["Title"] = "Perfil de Usuario";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Panel de Usuario</h1>
                    <p class="perfil-subtitle">
                        Accedé a tus cursos, horarios, pagos y más desde un solo lugar.
                    </p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-user"></i> Perfil Usuario
                </div>
            </div>

            <div class="perfil-grid">
                <div class="row g-4">

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-lock"></i>
                            <h3>Seguridad</h3>
                            <p>Actualizá tu contraseña para mantener protegida tu cuenta.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Auth"
                                   asp-action="CambiarPassword"
                                   class="perfil-btn">
                                    Cambiar Contraseña
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-book-open"></i>
                            <h3>Cursos Disponibles</h3>
                            <p>Explorá los cursos activos de la academia, niveles, horarios y profesores.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Usuario" asp-action="MisCursos" class="perfil-btn">
                                    Ver Cursos
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-clock"></i>
                            <h3>Horarios Disponibles</h3>
                            <p>Consultá los horarios de los cursos activos y filtrá por día.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Usuario" asp-action="MisHorarios" class="perfil-btn">
                                    Ver Horarios
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-file-signature"></i>
                            <h3>Matrícula</h3>
                            <p>Revisá el estado de tu matrícula e inscribite a cursos disponibles.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="Matricula" class="perfil-btn">
                                    Ver Matrícula
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-trophy"></i>
                            <h3>Campeonatos</h3>
                            <p>Ver torneos disponibles e inscribirte como jugador.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="Campeonatos" class="perfil-btn">
                                    Ver Campeonatos
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-chart-bar"></i>
                            <h3>Mi Progreso</h3>
                            <p>Revisá tu progreso técnico, metas y seguimiento de clases.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="Progreso" class="perfil-btn">
                                    Ver Progreso
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-wallet"></i>
                            <h3>Pagos</h3>
                            <p>Consultá el estado de tus pagos, suscripciones y recibos.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="UsuarioPagos" class="perfil-btn">
                                    Ver Pagos
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-bell"></i>
                            <h3>Notificaciones</h3>
                            <p>Revisá tus notificaciones y mensajes recientes.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="Notificaciones" class="perfil-btn">
                                    Ver Notificaciones
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-headset"></i>
                            <h3>Soporte</h3>
                            <p>¿Necesitás ayuda? Contactá al equipo de soporte de la academia.</p>
                            <div class="perfil-actions">
                                <a href="/#google-map" class="perfil-btn">
                                    Contactar
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>