@{
    ViewData["Title"] = "Mis Pagos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Mis Pagos</h1>
                    <p class="perfil-subtitle">
                        Consulta el estado de tus pagos actuales, montos pendientes y fechas de registro.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-credit-card"></i> Pagos del Usuario
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Pagos registrados</h2>

                    <div class="perfil-actions">
                        <a asp-controller="Home" asp-action="PerfilUsuario" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                    </div>
                </div>

                <div class="perfil-filter-row">
                    <input type="text" class="form-control" placeholder="Buscar por concepto..." />

                    <select class="form-select">
                        <option>Filtrar por estado</option>
                        <option>Pendiente</option>
                        <option>Pagado</option>
                    </select>
                </div>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Concepto</th>
                                <th>Monto</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th>Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>PAG-101</td>
                                <td>Matrícula anual</td>
                                <td>₡35,000</td>
                                <td>10/04/2026</td>
                                <td><span class="perfil-badge-warning">Pendiente</span></td>
                                <td><a href="#" class="perfil-action-link">Ver</a></td>
                            </tr>
                            <tr>
                                <td>PAG-102</td>
                                <td>Mensualidad abril</td>
                                <td>₡28,000</td>
                                <td>08/04/2026</td>
                                <td><span class="perfil-badge-success">Pagado</span></td>
                                <td><a href="#" class="perfil-action-link">Ver</a></td>
                            </tr>
                            <tr>
                                <td>PAG-103</td>
                                <td>Clase especial</td>
                                <td>₡12,000</td>
                                <td>06/04/2026</td>
                                <td><span class="perfil-badge-success">Pagado</span></td>
                                <td><a href="#" class="perfil-action-link">Ver</a></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</section>