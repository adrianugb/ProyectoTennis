@model List<ProyectoGrupalTennis.Models.AdminFacturaItemViewModel>
@{
    ViewData["Title"] = "Facturación";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Facturación</h1>
                    <p class="perfil-subtitle">Consulta y descarga las facturas generadas.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-file-text"></i> Facturación
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de facturas</h2>
                    <div class="perfil-actions">
                        <a asp-controller="Home" asp-action="AdminFacturacion" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                    </div>
                </div>

                <form method="get" asp-action="AdminFacturas">
                    <div class="perfil-filter-row">
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar por alumno o número de factura..."
                               value="@ViewBag.FiltroBuscar" />
                        <button type="submit" class="perfil-btn">
                            <i class="fa fa-search"></i> Buscar
                        </button>
                        <a asp-action="AdminFacturas" class="perfil-btn-outline">Limpiar</a>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>No. Factura</th>
                                <th>Alumno</th>
                                <th>Concepto</th>
                                <th>Monto</th>
                                <th>Fecha</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        No hay facturas generadas.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var f in Model)
                                {
                                    <tr>
                                        <td><strong>@f.NumeroFactura</strong></td>
                                        <td>@f.Alumno</td>
                                        <td>@f.Concepto</td>
                                        <td>₡@f.Monto.ToString("N0")</td>
                                        <td>@f.FechaFactura.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <a asp-controller="Admin"
                                               asp-action="DescargarFactura"
                                               asp-route-idPago="@f.IdPago"
                                               class="perfil-action-link">
                                                <i class="fa fa-download"></i> Descargar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>