@model ProyectoGrupalTennis.Models.ProfesorCursosViewModel
@{
	ViewData["Title"] = "Mis Cursos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
	<div class="container">
		<div class="perfil-container">

			<div class="perfil-header">
				<div>
					<h1 class="perfil-title">Mis Cursos</h1>
					<p class="perfil-subtitle">
						Visualiza los cursos disponibles, niveles y horarios de la academia.
					</p>
				</div>
				<div class="perfil-badge">
					<i class="fa fa-book"></i> Catálogo de Cursos
				</div>
			</div>

			<div class="perfil-table-block">
				<div class="perfil-table-header">
					<h2 class="perfil-table-title">Listado de cursos</h2>
				</div>

				@* ── Filtros: se envían al servidor al hacer submit ── *@
				<form method="get" asp-controller="PerfilProfesor" asp-action="MisCursos">
					<div class="perfil-filter-row">
						<input type="text" name="buscar" class="form-control"
							   placeholder="Buscar curso..."
							   value="@Model.FiltroBuscar" />

						<select name="nivel" class="form-select">
							<option value="">Filtrar por nivel</option>
							<option value="Básico" @(Model.FiltroNivel == "Básico" ? "selected" : "")>Básico</option>
							<option value="Intermedio" @(Model.FiltroNivel == "Intermedio" ? "selected" : "")>Intermedio</option>
							<option value="Avanzado" @(Model.FiltroNivel == "Avanzado" ? "selected" : "")>Avanzado</option>
						</select>

						<button type="submit" class="btn btn-primary">
							<i class="fa fa-search me-1"></i> Buscar
						</button>

						@if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar) || !string.IsNullOrWhiteSpace(Model.FiltroNivel))
						{
							<a asp-controller="PerfilProfesor" asp-action="MisCursos" class="btn btn-secondary">
								<i class="fa fa-times me-1"></i> Limpiar
							</a>
						}
					</div>
				</form>

				<div class="table-responsive">
					<table class="perfil-table" id="tablaCursos">
						<thead>
							<tr>
								<th>Curso</th>
								<th>Nivel</th>
								<th>Horarios</th>
								<th>Cupos</th>
								<th>Estado</th>
							</tr>
						</thead>
						<tbody>
							@if (!Model.Cursos.Any())
							{
								<tr>
									<td colspan="5" class="text-center text-muted py-4">
										<i class="fa fa-book fa-2x mb-2 d-block"></i>
										No hay cursos disponibles con los criterios indicados.
									</td>
								</tr>
							}
							else
							{
								@foreach (var curso in Model.Cursos)
								{
									<tr>
										<td>
											<strong>@curso.Nombre</strong>
											@if (!string.IsNullOrWhiteSpace(curso.Descripcion))
											{
												<br /><small class="text-muted">@curso.Descripcion</small>
											}
										</td>
										<td>@curso.Nivel</td>
										<td>
											@if (curso.Horarios.Any())
											{
												@foreach (var h in curso.Horarios)
												{
													<small class="d-block">@h</small>
												}
											}
											else
											{
												<small class="text-muted">Sin horario asignado</small>
											}
										</td>
										<td>@curso.CuposDisponibles</td>
										<td>
											@if (curso.Activo)
											{
												<span class="perfil-badge-success">Activo</span>
											}
											else
											{
												<span class="perfil-badge-warning">Inactivo</span>
											}
										</td>
									</tr>
								}
							}
						</tbody>
					</table>
				</div>

			</div>
		</div>
	</div>
</section>