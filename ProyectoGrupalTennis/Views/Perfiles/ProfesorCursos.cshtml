@model ProyectoGrupalTennis.Models.ProfesorMisCursosViewModel
    ViewData["Title"] = "Mis Cursos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Mis Cursos</h1>
                    <p class="perfil-subtitle">Visualiza tus cursos asignados y gestioná los horarios.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-book"></i> Mis Cursos
                </div>
            </div>

            <div class="mb-3">
                <a asp-controller="Home" asp-action="PerfilProfesor" class="btn-volver">
                    <i class="fa fa-arrow-left"></i> Volver al Panel
                </a>
            </div>

            @if (!string.IsNullOrEmpty(Model.MensajeExito))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa fa-check-circle me-2"></i> @Model.MensajeExito
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.MensajeError))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fa fa-exclamation-circle me-2"></i> @Model.MensajeError
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de cursos</h2>
                </div>

                <form method="get" asp-controller="PerfilProfesor" asp-action="MisCursos">
                    <div class="perfil-filter-row">
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar curso..." value="@Model.FiltroBuscar" />
                        <select name="nivel" class="form-select">
                            <option value="">Todos los niveles</option>
                            <option value="Principiante" selected="@(Model.FiltroNivel == "Principiante")">Principiante</option>
                            <option value="Intermedio" selected="@(Model.FiltroNivel == "Intermedio")">Intermedio</option>
                            <option value="Avanzado" selected="@(Model.FiltroNivel == "Avanzado")">Avanzado</option>
                        </select>
                        <button type="submit" class="perfil-btn">
                            <i class="fa fa-search me-1"></i> Buscar
                        </button>
                        @if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar) || !string.IsNullOrWhiteSpace(Model.FiltroNivel))
                        {
                            <a asp-controller="PerfilProfesor" asp-action="MisCursos" class="perfil-btn-outline">
                                <i class="fa fa-times me-1"></i> Limpiar
                            </a>
                        }
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>Curso</th>
                                <th>Nivel</th>
                                <th>Clases programadas</th>
                                <th>Cupos</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Cursos.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="fa fa-book fa-2x mb-2 d-block"></i>
                                        No hay cursos asignados.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var curso in Model.Cursos)
                                {
                                    <tr>
                                        <td>
                                            <strong>@curso.Nombre</strong>
                                            @if (!string.IsNullOrWhiteSpace(curso.Descripcion))
                                            {
                                                <br /><small class="text-muted">@curso.Descripcion</small>
                                            }
                                        </td>
                                        <td>@curso.Nivel</td>
                                        <td>
                                            @if (curso.Horarios.Any())
                                            {
                                                @foreach (var h in curso.Horarios)
                                                {
                                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
                                                        <small>
                                                            <i class="fa fa-calendar" style="color:#a5c422;"></i>
                                                            @DateTime.Parse(h.Fecha).ToString("dd/MM/yyyy")
                                                            (@h.DiaSemana)
                                                            &nbsp;
                                                            <i class="fa fa-clock-o" style="color:#a5c422;"></i>
                                                            @h.HoraInicio - @h.HoraFin
                                                        </small>
                                                        <a asp-controller="PerfilProfesor"
                                                           asp-action="ReprogramarClase"
                                                           asp-route-idHorario="@h.IdHorario"
                                                           class="perfil-action-link"
                                                           style="font-size:11px;">
                                                            <i class="fa fa-pencil"></i> Reprogramar
                                                        </a>
                                                        <form asp-controller="PerfilProfesor"
                                                              asp-action="CancelarClase"
                                                              method="post" style="display:inline;"
                                                              onsubmit="return confirm('¿Cancelar la clase del @DateTime.Parse(h.Fecha).ToString("dd/MM/yyyy")? Se notificará a los alumnos.');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="idHorario" value="@h.IdHorario" />
                                                            <input type="hidden" name="idCurso" value="@curso.IdCurso" />
                                                            <button type="submit"
                                                                    class="perfil-action-link text-danger"
                                                                    style="background:none;border:none;padding:0;cursor:pointer;font-size:11px;">
                                                                <i class="fa fa-times"></i> Cancelar clase
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <small class="text-muted">Sin clases programadas</small>
                                            }
                                        </td>
                                        <td>@curso.CuposDisponibles</td>
                                        <td>
                                            @if (curso.Activo)
                                            {
                                                <span class="perfil-badge-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-warning">Inactivo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
