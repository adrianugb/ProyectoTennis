@model ProyectoGrupalTennis.Models.GestionCursosViewModel
@{
    ViewData["Title"] = "Gestión de Cursos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Cursos</h1>
                    <p class="perfil-subtitle">Administrá cursos, profesores y horarios de la academia.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-book"></i> Administración de Cursos
                </div>
            </div>

            <div class="mb-3">
                <a asp-controller="Home" asp-action="PerfilAdmin" class="btn-volver">
                    <i class="fa fa-arrow-left"></i> Volver al Panel
                </a>
            </div>

            @if (!string.IsNullOrEmpty(Model.MensajeExito))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa fa-check-circle me-2"></i> @Model.MensajeExito
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.MensajeError))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fa fa-exclamation-circle me-2"></i> @Model.MensajeError
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            }

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de cursos</h2>
                    <div class="perfil-actions">
                        <a asp-controller="Curso" asp-action="Agregar" class="perfil-btn">
                            <i class="fa fa-plus"></i> Agregar curso
                        </a>
                    </div>
                </div>

                <form method="get" asp-controller="Curso" asp-action="Index">
                    <div class="perfil-filter-row">
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar curso..." value="@Model.FiltroBuscar" />
                        <select name="nivel" class="form-select">
                            <option value="">Filtrar por nivel</option>
                            <option value="Principiante" selected="@(Context.Request.Query["nivel"] == "Principiante")">Principiante</option>
                            <option value="Intermedio" selected="@(Context.Request.Query["nivel"] == "Intermedio")">Intermedio</option>
                            <option value="Avanzado" selected="@(Context.Request.Query["nivel"] == "Avanzado")">Avanzado</option>
                        </select>
                        <select name="estado" class="form-select">
                            <option value="">Filtrar por estado</option>
                            <option value="Activo" selected="@(Context.Request.Query["estado"] == "Activo")">Activo</option>
                            <option value="Inactivo" selected="@(Context.Request.Query["estado"] == "Inactivo")">Inactivo</option>
                        </select>
                        <button type="submit" class="perfil-btn">
                            <i class="fa fa-search me-1"></i> Buscar
                        </button>
                        @if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar))
                        {
                            <a asp-controller="Curso" asp-action="Index" class="perfil-btn-outline">
                                <i class="fa fa-times me-1"></i> Limpiar
                            </a>
                        }
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Nivel</th>
                                <th>Horarios</th>
                                <th>Profesor</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Cursos.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="fa fa-book fa-2x mb-2 d-block"></i>
                                        No hay cursos registrados en el sistema.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var curso in Model.Cursos)
                                {
                                    <tr>
                                        <td>CUR-@curso.IdCurso.ToString("D3")</td>
                                        <td><strong>@curso.Nombre</strong></td>
                                        <td>@curso.Nivel</td>
                                        <td>
                                            @if (curso.Horarios != null && curso.Horarios.Any())
                                            {
                                                @foreach (var h in curso.Horarios)
                                                {
                                                    <small class="d-block">@h</small>
                                                }
                                            }
                                            else
                                            {
                                                <small class="text-muted">Sin horario</small>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(curso.NombreProfesor))
                                            {
                                                <span class="perfil-badge-success">@curso.NombreProfesor</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Sin asignar</span>
                                            }
                                        </td>
                                        <td>
                                            @if (curso.Activo)
                                            {
                                                <span class="perfil-badge-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-warning">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="Curso" asp-action="Editar"
                                               asp-route-id="@curso.IdCurso"
                                               class="perfil-action-link">Editar</a>

                                            <span class="perfil-action-separator">|</span>

                                            <form asp-controller="Curso" asp-action="CambiarEstado"
                                                  method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@curso.IdCurso" />
                                                <input type="hidden" name="activo" value="@(!curso.Activo)" />
                                                <button type="submit" class="perfil-action-link"
                                                        style="background:none;border:none;padding:0;cursor:pointer;">
                                                    @(curso.Activo ? "Desactivar" : "Activar")
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
