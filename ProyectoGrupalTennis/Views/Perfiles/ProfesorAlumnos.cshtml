@model ProyectoGrupalTennis.Models.ProfesorAlumnosViewModel
@{
    ViewData["Title"] = "Alumnos por Clase";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container-fluid px-4">
        <div class="perfil-container perfil-container-wide">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Alumnos por Clase</h1>
                    <p class="perfil-subtitle">
                        Visualiza la información de los alumnos matriculados en los cursos de la academia.
                    </p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-users"></i> Alumnos Matriculados
                </div>
            </div>

            <div class="mb-3">
                <a asp-controller="Home" asp-action="PerfilProfesor" class="btn-volver">
                    <i class="fa fa-arrow-left"></i> Volver al Panel
                </a>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de alumnos por clase</h2>
                </div>

                <form method="get" asp-controller="PerfilProfesor" asp-action="MisAlumnos">
                    <div class="perfil-filter-row">
                        <input type="text"
                               name="buscar"
                               class="form-control"
                               placeholder="Buscar alumno..."
                               value="@Model.FiltroBuscar" />

                        <select name="curso" class="form-select">
                            <option value="">Filtrar por clase</option>
                            @foreach (var c in Model.CursosDisponibles)
                            {
                                if (Model.FiltroCurso == c)
                                {
                                    <option value="@c" selected>@c</option>
                                }
                                else
                                {
                                    <option value="@c">@c</option>
                                }
                            }
                        </select>

                        <input type="date"
                               name="fecha"
                               class="form-control"
                               value="@Model.FiltroFecha"
                               style="max-width:220px;" />

                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search me-1"></i> Buscar
                        </button>

                        @if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar)
                            || !string.IsNullOrWhiteSpace(Model.FiltroCurso)
                            || !string.IsNullOrWhiteSpace(Model.FiltroFecha))
                        {
                            <a asp-controller="PerfilProfesor"
                               asp-action="MisAlumnos"
                               class="btn btn-secondary">
                                <i class="fa fa-times me-1"></i> Limpiar
                            </a>
                        }
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table" id="tablaAlumnos">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Alumno</th>
                                <th>Correo</th>
                                <th>Teléfono</th>
                                <th>Clase</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Alumnos.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="fa fa-users fa-2x mb-2 d-block"></i>
                                        @if (!string.IsNullOrWhiteSpace(Model.FiltroBuscar)
                                            || !string.IsNullOrWhiteSpace(Model.FiltroCurso)
                                            || !string.IsNullOrWhiteSpace(Model.FiltroFecha))
                                        {
                                            <span>No se encontraron alumnos con los criterios indicados.</span>
                                        }
                                        else
                                        {
                                            <span>No existen alumnos registrados para las clases disponibles.</span>
                                        }
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var alumno in Model.Alumnos)
                                {
                                    <tr>
                                        <td><strong>@alumno.FechaClase</strong></td>
                                        <td>@alumno.HoraClase</td>
                                        <td>@alumno.NombreCompleto</td>
                                        <td>@alumno.Correo</td>
                                        <td>@alumno.Telefono</td>
                                        <td>@alumno.Clase</td>
                                        <td>
                                            @if (alumno.Activo)
                                            {
                                                <span class="perfil-badge-success">@alumno.EstadoMatricula</span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-warning">Inactivo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="perfil-table-block" style="margin-top: 24px;">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Agenda semanal de clases</h2>
                </div>

                @{
                    var diasSemana = new[] { "lunes", "martes", "miércoles", "jueves", "viernes", "sábado", "domingo" };
                    var horas = Enumerable.Range(5, 18).ToList();
                }

                @if (!Model.Alumnos.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="fa fa-calendar fa-2x mb-2 d-block"></i>
                        <span>No hay clases programadas para mostrar en la agenda.</span>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="perfil-table agenda-calendar-table">
                            <thead>
                                <tr>
                                    <th>Hora</th>
                                    <th>Lunes</th>
                                    <th>Martes</th>
                                    <th>Miércoles</th>
                                    <th>Jueves</th>
                                    <th>Viernes</th>
                                    <th>Sábado</th>
                                    <th>Domingo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hora in horas)
                                {
                                    <tr>
                                        <td>
                                            <strong>@($"{hora:00}:00")</strong>
                                        </td>

                                        @foreach (var dia in diasSemana)
                                        {
                                            var clasesDelDia = Model.Alumnos
                                                .Where(a => a.DiaSemana.ToLower() == dia && a.HoraInicioEntera == hora)
                                                .ToList();

                                            <td>
                                                @if (clasesDelDia.Any())
                                                {
                                                    foreach (var clase in clasesDelDia)
                                                    {
                                                        <div class="agenda-calendar-card">
                                                            <strong>@clase.NombreCompleto</strong>
                                                            <br />
                                                            <span>@clase.Clase</span>
                                                            <br />
                                                            <small>@clase.HoraClase</small>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    </div>
</section>