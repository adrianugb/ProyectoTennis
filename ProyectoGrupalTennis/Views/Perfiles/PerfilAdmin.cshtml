@{
    ViewData["Title"] = "Perfil Administrativo";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Panel Administrativo</h1>
                    <p class="perfil-subtitle">
                        Gestiona cursos, alumnos, profesores y facturación desde un solo lugar.
                    </p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-user-shield"></i> Perfil Administrador
                </div>
            </div>

            <div class="perfil-grid">
                <div class="row">

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-book"></i>
                            <h3>Gestión de Cursos</h3>
                            <p>Administra el catálogo de cursos y asigná profesores.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Curso" asp-action="Index" class="perfil-btn">
                                    Ir a Cursos
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-user-graduate"></i>
                            <h3>Gestión de Alumnos</h3>
                            <p>Consulta, registra, edita y visualiza la información general de los alumnos.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Alumnos" asp-action="Index" class="perfil-btn">
                                    Ir a Alumnos
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-table-tennis"></i>
                            <h3>Gestión de Canchas</h3>
                            <p>Administrá la disponibilidad y mantenimiento de las canchas de la academia.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Canchas" asp-action="Index" class="perfil-btn">
                                    Ir a Canchas
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-chalkboard-teacher"></i>
                            <h3>Gestión de Profesores</h3>
                            <p>Visualiza y administra la información relacionada con los profesores.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="AdminProfesores" class="perfil-btn">
                                    Ir a Profesores
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-file-invoice-dollar"></i>
                            <h3>Pagos y Facturación</h3>
                            <p>Registra pagos, confirma transacciones y consulta el historial financiero.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Home" asp-action="AdminFacturacion" class="perfil-btn">
                                    Ir a Facturación
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-users-cog"></i>
                            <h3>Gestión de Usuarios</h3>
                            <p>Administra usuarios del sistema, roles, accesos y estados de bloqueo.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Admin" asp-action="Index" class="perfil-btn">
                                    Ir a Usuarios
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-sm-6">
                        <div class="perfil-card">
                            <i class="fa fa-tags"></i>
                            <h3>Gestión de Ofertas</h3>
                            <p>Crea y administra códigos de descuento y promociones.</p>
                            <div class="perfil-actions">
                                <a asp-controller="Offers" asp-action="Index" class="perfil-btn">
                                    Ir a Ofertas
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>