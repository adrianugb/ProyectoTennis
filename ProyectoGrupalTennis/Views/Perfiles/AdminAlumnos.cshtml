@{
    ViewData["Title"] = "Gestión de Alumnos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Alumnos</h1>
                    <p class="perfil-subtitle">
                        Consulta, registra, modifica y administra la información general de los alumnos.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-user-graduate"></i> Administración de Alumnos
                </div>
            </div>

            <div class="perfil-table-block">
