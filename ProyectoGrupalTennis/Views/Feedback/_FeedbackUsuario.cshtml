<div class="module-block">
    <h1 class="module-title">Encuesta de Satisfacción - Alumno</h1>
    <p class="module-subtitle">
        Formulario visual para evaluar la clase, al profesor y el curso.
    </p>

    <div style="margin-bottom: 15px;">
        <label>¿Cómo califica la clase recibida?</label>
        <select class="form-control">
            <option>Excelente</option>
            <option>Muy buena</option>
            <option>Buena</option>
            <option>Regular</option>
        </select>
    </div>

    <div style="margin-bottom: 15px;">
        <label>¿Cómo califica al profesor?</label>
        <select class="form-control">
            <option>5 estrellas</option>
            <option>4 estrellas</option>
            <option>3 estrellas</option>
            <option>2 estrellas</option>
            <option>1 estrella</option>
        </select>
    </div>

    <div style="margin-bottom: 20px;">
        <label>Comentarios adicionales</label>
        <textarea class="form-control" rows="5" placeholder="Escriba aquí sus comentarios"></textarea>
    </div>

    <div class="module-actions">
        <button class="module-btn">Enviar encuesta</button>
    </div>
</div>