<div class="page-header">
    <h1>Configuración de Encuestas</h1>
    <p>Definición visual de preguntas y criterios de evaluación.</p>
</div>

<div class="form-box">
    <div class="filters">
        <input type="text" placeholder="Título de la encuesta" />
        <select>
            <option>Después de cada clase</option>
            <option>Mensual</option>
            <option>Por curso</option>
        </select>
    </div>

    <input type="text" placeholder="Pregunta 1: ¿Cómo califica la clase?" style="margin-bottom: 12px;" />
    <input type="text" placeholder="Pregunta 2: ¿Cómo califica al profesor?" style="margin-bottom: 12px;" />
    <input type="text" placeholder="Pregunta 3: Comentarios adicionales" style="margin-bottom: 12px;" />

    <div class="action-row">
        <button class="btn-custom">Guardar configuración</button>
        <button class="btn-custom" onclick="mostrarVista('feedback-admin')">Volver</button>
    </div>
</div>