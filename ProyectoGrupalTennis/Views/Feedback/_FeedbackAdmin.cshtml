                        <td><span class="badge-soft-success">Excelente</span></td>
                    </tr>
                    <tr>
                        <td>Intermedio Juvenil</td>
                        <td>Carlos Ramírez</td>
                        <td>4.5/5</td>
                        <td>90%</td>
                        <td><span class="badge-soft-warning">Estable</span></td>
                    </tr>
                    <tr>
                        <td>Avanzado Competitivo</td>
                        <td>Ana Gómez</td>
                        <td>4.2/5</td>
                        <td>88%</td>
                        <td><span class="badge-soft-danger">Seguimiento</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
