<div class="module-block">
    <h2 class="module-title">Feedback - Administrador</h2>
    <p class="module-subtitle">
        Consulta los resultados consolidados de satisfacción de los alumnos, analiza el desempeño de los entrenadores
        y supervisa la calidad de los entrenamientos ofrecidos por la academia de tenis.
    </p>

    <div class="row">
        <div class="col-md-3 col-sm-6">
            <div class="module-card">
                <h3>4.7/5</h3>
                <p>Promedio general</p>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="module-card">
                <h3>92%</h3>
                <p>Participación en encuestas</p>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="module-card">
                <h3>145</h3>
                <p>Respuestas del mes</p>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="module-card">
                <h3>8</h3>
                <p>Grupos evaluados</p>
            </div>
        </div>
    </div>

    <div class="module-block" style="margin-top: 10px; padding: 25px;">
        <h4 style="margin-bottom: 18px; font-weight: 700; color: #252525;">Resumen consolidado</h4>

        <div class="table-responsive">
            <table class="table report-table">
                <thead>
                    <tr>
                        <th>Grupo</th>
                        <th>Entrenador</th>
                        <th>Promedio</th>
                        <th>Participación</th>
                        <th>Estado</th>
