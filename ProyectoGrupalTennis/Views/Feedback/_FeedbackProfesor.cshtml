<div class="module-block">
    <h2 class="module-title">Feedback - Entrenador</h2>
    <p class="module-subtitle">
        Consulta las evaluaciones realizadas por los alumnos, analiza tu desempeño en los entrenamientos
        y revisa comentarios para mejorar la calidad de tus sesiones.
    </p>

    <!-- Stats -->
    <div class="row">
        <div class="col-md-4 col-sm-6">
            <div class="module-card">
                <h3>4.8/5</h3>
                <p>Promedio general</p>
            </div>
        </div>

        <div class="col-md-4 col-sm-6">
            <div class="module-card">
                <h3>38</h3>
                <p>Comentarios recibidos</p>
            </div>
        </div>

        <div class="col-md-4 col-sm-6">
            <div class="module-card">
                <h3>95%</h3>
                <p>Satisfacción de alumnos</p>
            </div>
        </div>
    </div>

    <!-- Evaluación por criterio -->
    <div class="module-block" style="margin-top: 20px; padding: 25px;">
        <h4 style="margin-bottom: 18px; font-weight: 700;">Evaluación por criterio</h4>

        <div class="row">
            <div class="col-md-4">
                <div class="module-card">
                    <h3>4.9</h3>
                    <p>Técnica</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="module-card">
                    <h3>4.7</h3>
                    <p>Comunicación</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="module-card">
                    <h3>4.6</h3>
                    <p>Dinámica del entrenamiento</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Comentarios -->
    <div class="module-block" style="margin-top: 20px; padding: 25px;">
        <h4 style="margin-bottom: 18px; font-weight: 700;">Comentarios de alumnos</h4>

        <div class="table-responsive">
            <table class="table report-table">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Comentario</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="badge-soft-success">Destacado</span></td>
