@model ProyectoGrupalTennis.Models.UsuarioCursosViewModel

<div class="dashboard-block">
    <h1 class="page-title">Cursos Disponibles</h1>
    <p class="page-subtitle">Elige el curso que mejor se adapte a tu nivel y horario.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <form method="get" asp-controller="Usuario" asp-action="MisCursos">
        <div class="row" style="margin-bottom: 20px;">
            <div class="col-md-4">
                <input type="text"
                       name="buscar"
                       class="form-control"
                       placeholder="Buscar cursos..."
                       value="@Model.FiltroBuscar" />
            </div>

            <div class="col-md-3">
                <select name="nivel" class="form-control">
                    <option value="">Todos los niveles</option>
                    <option value="Principiante" selected="@(Model.FiltroNivel == "Principiante")">Principiante</option>
                    <option value="Intermedio" selected="@(Model.FiltroNivel == "Intermedio")">Intermedio</option>
                    <option value="Avanzado" selected="@(Model.FiltroNivel == "Avanzado")">Avanzado</option>
                </select>
            </div>

            <div class="col-md-3">
                <button type="submit" class="module-btn">
                    <i class="fa fa-search"></i> Buscar
                </button>
            </div>
        </div>
    </form>

    @if (!Model.Cursos.Any())
    {
        <div class="alert alert-info">
            No existen cursos disponibles con los filtros seleccionados.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var curso in Model.Cursos)
            {
                <div class="col-md-4" style="margin-bottom:20px;">
                    <div class="module-card" style="border-top: 4px solid #a5c422;height:100%;">
                        <i class="fa fa-star"></i>

                        <h3>@curso.Nombre</h3>

                        <p>@curso.Descripcion</p>

                        <p style="font-size: 13px; color: #555; margin-top: 8px;">
                            <i class="fa fa-signal" style="color: #a5c422;"></i>
                            @curso.Nivel
                            <br />

                            <i class="fa fa-users" style="color: #a5c422;"></i>
                            @curso.CuposDisponibles cupos disponibles
                            <br />

                            <i class="fa fa-user" style="color: #a5c422;"></i>
                            @curso.NombreProfesor
                            <br />

                            <i class="fa fa-clock-o" style="color: #a5c422;"></i>
                            @if (curso.Horarios.Any())
                            {
                                @string.Join(", ", curso.Horarios)
                            }
                            else
                            {
                                <span>Sin horarios registrados</span>
                            }
                        </p>

                        <div class="module-actions" style="justify-content: center;">
                            @if (curso.CuposDisponibles > 0)
                            {
                                <form asp-controller="Usuario"
                                      asp-action="MatricularCurso"
                                      method="post"
                                      onsubmit="return confirm('¿Deseas matricularte en este curso?');">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="idCurso" value="@curso.IdCurso" />

                                    <button type="submit" class="module-btn">
                                        Matricular <i class="fa fa-arrow-right"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="module-btn" disabled style="opacity:0.6;cursor:not-allowed;">
                                    Sin cupos
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>