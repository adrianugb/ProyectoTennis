<div class="dashboard-block">
    <h1 class="page-title">Dashboard del Alumno</h1>
    <p class="page-subtitle">
        Resumen general del progreso, clases y actividad del estudiante.
    </p>

    <!-- Estadísticas -->
    <div class="row">
        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <i class="fa fa-calendar"></i>
                <h3>4</h3>
                <p>Clases esta semana</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <i class="fa fa-trophy"></i>
                <h3>2</h3>
                <p>Torneos inscritos</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <i class="fa fa-signal"></i>
                <h3>Avanzado</h3>
                <p>Nivel actual</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <i class="fa fa-line-chart"></i>
                <h3>87%</h3>
                <p>Asistencia mensual</p>
            </div>
        </div>
    </div>

    <!-- Paneles -->
    <div class="row" style="margin-top: 10px;">
        <div class="col-md-6">
            <div class="dashboard-card">
                <i class="fa fa-clock-o"></i>
                <h3>Próxima clase</h3>
                <p>
                    Martes, 5:00 p.m. con el profesor asignado.
                </p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="dashboard-card">
                <i class="fa fa-bullseye"></i>
                <h3>Objetivos técnicos</h3>
                <p>
                    Consulta rápida de metas y habilidades a mejorar.
                </p>
            </div>
        </div>
    </div>
</div>