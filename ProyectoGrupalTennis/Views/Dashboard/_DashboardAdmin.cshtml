@model ProyectoGrupalTennis.Models.DashboardAdminViewModel

<div class="dashboard-block">
    <div class="dashboard-header">
        <div>
            <h1 class="page-title">Administrador</h1>
            <p class="page-subtitle">
                Panel general con indicadores clave para supervisar el estado actual de la academia.
            </p>
        </div>

        <div class="dashboard-status-badge">
            <i class="fa fa-circle"></i> Actualizado hoy
        </div>
    </div>

    <!-- Filtros (ADM-08-004) -->
    <div class="dashboard-filter-box">
        <div class="row">
            <div class="col-md-3">
                <label class="filter-label">Fecha inicial</label>
                <input type="date" id="filtroFechaInicio" class="form-control" value="@Model.FechaInicio.ToString("yyyy-MM-dd")">
            </div>

            <div class="col-md-3">
                <label class="filter-label">Fecha final</label>
                <input type="date" id="filtroFechaFin" class="form-control" value="@Model.FechaFin.ToString("yyyy-MM-dd")">
            </div>

            <div class="col-md-3">
                <label class="filter-label">Periodo rápido</label>
                <select class="form-control" id="filtroPeriodoRapido" onchange="aplicarPeriodoRapido()">
                    <option value="">Personalizado</option>
                    <option value="7">Últimos 7 días</option>
                    <option value="mes">Este mes</option>
                    <option value="trimestre">Último trimestre</option>
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button type="button" class="dashboard-mini-btn" style="width: 100%;" onclick="aplicarFiltroDashboardAdmin()">
                    <i class="fa fa-filter"></i> Aplicar filtro
                </button>
            </div>
        </div>
    </div>

    <!-- Resumen del periodo -->
    <div class="dashboard-summary-strip">
        <div class="summary-item">
            <span class="summary-title">Periodo analizado</span>
            <strong>@Model.FechaInicio.ToString("dd MMMM yyyy") - @Model.FechaFin.ToString("dd MMMM yyyy")</strong>
        </div>

        <div class="summary-item">
            <span class="summary-title">Estado general</span>
            <strong>@(Model.ClasesProgramadas > 0 ? "Operación activa" : "Sin actividad en el periodo")</strong>
        </div>

        <div class="summary-item">
            <span class="summary-title">Alumnos nuevos</span>
            <strong>+@Model.AlumnosNuevosEnPeriodo en el periodo</strong>
        </div>
    </div>

    <!-- KPIs (ADM-08-001 / ADM-08-002 / ADM-08-003) -->
    <div class="row">
        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-users"></i>
                    <span class="stat-badge positive">+@Model.AlumnosNuevosEnPeriodo</span>
                </div>
                <h3>@Model.AlumnosActivos</h3>
                <p>Alumnos activos</p>
                <small>Participación actual en la plataforma</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-calendar-alt"></i>
                    <span class="stat-badge neutral">@Model.ClasesProgramadas</span>
                </div>
                <h3>@Model.ClasesProgramadas</h3>
                <p>Clases programadas</p>
                <small>Carga operativa del periodo seleccionado</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-chalkboard-teacher"></i>
                    <span class="stat-badge positive">Activos</span>
                </div>
                <h3>@Model.ProfesoresActivos</h3>
                <p>Profesores registrados</p>
                <small>Docentes disponibles para impartir clases</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-money-bill-wave"></i>
                </div>
                <h3>₡@Model.IngresosPeriodo.ToString("N0")</h3>
                <p>Ingresos del periodo</p>
                <small>Resumen económico general</small>
            </div>
        </div>
    </div>

    <!-- Panel secundario -->
    <div class="row" style="margin-top: 30px;">
        <div class="col-md-8">
            <div class="dashboard-card">
                <div class="card-header-custom">
                    <h3><i class="fa fa-list"></i> Clases programadas</h3>
                    <span class="mini-label">Vista rápida del periodo</span>
                </div>

                <div class="table-responsive">
                    <table class="table custom-table">
                        <thead>
                            <tr>
                                <th>Clase</th>
                                <th>Profesor</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Cupos</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ClasesDelPeriodo.Any())
                            {
                                @foreach (var clase in Model.ClasesDelPeriodo)
                                {
                                    var badgeClass = clase.CuposOcupados >= clase.CuposTotales && clase.CuposTotales > 0
                                        ? "badge-soft-warning"
                                        : clase.Estado == "Cancelada" ? "badge-soft-danger" : "badge-soft-success";

                                    <tr>
                                        <td>@clase.NombreCurso</td>
                                        <td>@clase.Profesor</td>
                                        <td>@clase.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td>@clase.HoraInicio.ToString(@"hh\:mm")</td>
                                        <td>@clase.CuposOcupados / @clase.CuposTotales</td>
                                        <td><span class="badge-soft @badgeClass">@clase.Estado</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center">No hay clases programadas en el periodo seleccionado.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card" style="margin-bottom: 20px;">
                <div class="card-header-custom">
                    <h3><i class="fa fa-bell"></i> Alertas rápidas</h3>
                </div>

                <ul class="dashboard-alert-list">
                    @if (Model.Alertas.Any())
                    {
                        @foreach (var alerta in Model.Alertas)
                        {
                            <li><i class="fa fa-exclamation-circle"></i> @alerta</li>
                        }
                    }
                    else
                    {
                        <li><i class="fa fa-check-circle"></i> No hay alertas para este periodo.</li>
                    }
                </ul>
            </div>

            <div class="dashboard-card">
                <div class="card-header-custom">
                    <h3><i class="fa fa-bolt"></i> Accesos rápidos</h3>
                </div>

                <div class="quick-actions">
                    <button class="dashboard-mini-btn" onclick="mostrarVista('dashboard-admin-dashboard')">
                        Ver Dashboard
                    </button>

                    <button class="dashboard-mini-btn" onclick="mostrarVista('dashboard-admin-reportes')">
                        Ir a Reportes
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>