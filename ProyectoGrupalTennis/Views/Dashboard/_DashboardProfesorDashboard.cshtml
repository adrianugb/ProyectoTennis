<div class="dashboard-block">
    <div class="dashboard-header">
        <div>
            <h1 class="page-title">Dashboard del Profesor</h1>
            <p class="page-subtitle">
                Resumen visual del desempeño docente, avance de clases, evaluaciones registradas y seguimiento general del grupo.
            </p>
        </div>

        <div class="dashboard-status-badge">
            <i class="fa fa-chalkboard-teacher"></i> Panel docente
        </div>
    </div>

    <!-- Resumen del día -->
    <div class="dashboard-summary-strip">
        <div class="summary-item">
            <span class="summary-title">Jornada actual</span>
            <strong>3 clases programadas</strong>
        </div>

        <div class="summary-item">
            <span class="summary-title">Asistencia promedio</span>
            <strong>92%</strong>
        </div>

        <div class="summary-item">
            <span class="summary-title">Estado general</span>
            <strong>Buen rendimiento</strong>
        </div>
    </div>

    <!-- Estadísticas -->
    <div class="row">
        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-check-circle"></i>
                    <span class="stat-badge positive">+1</span>
                </div>
                <h3>4</h3>
                <p>Clases completadas</p>
                <small>Sesiones finalizadas correctamente</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-clock-o"></i>
                    <span class="stat-badge neutral">Hoy</span>
                </div>
                <h3>2</h3>
                <p>Clases pendientes</p>
                <small>Sesiones por impartir en el día</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-pencil-square-o"></i>
                    <span class="stat-badge positive">+5</span>
                </div>
                <h3>15</h3>
                <p>Evaluaciones registradas</p>
                <small>Seguimiento académico actualizado</small>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-stat-card">
                <div class="stat-top">
                    <i class="fa fa-line-chart"></i>
                    <span class="stat-badge positive">Óptimo</span>
                </div>
                <h3>95%</h3>
                <p>Puntualidad del día</p>
                <small>Cumplimiento de horarios programados</small>
            </div>
        </div>
    </div>

    <!-- Paneles -->
    <div class="row" style="margin-top: 30px;">
        <div class="col-md-8">
            <div class="dashboard-card">
                <div class="card-header-custom">
                    <h3><i class="fa fa-calendar"></i> Próximas clases</h3>
                    <span class="mini-label">Agenda inmediata</span>
                </div>

                <div class="table-responsive">
                    <table class="table custom-table">
                        <thead>
                            <tr>
                                <th>Clase</th>
                                <th>Grupo</th>
                                <th>Hora</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Natación básica</td>
                                <td>Infantil A</td>
                                <td>8:00 a.m.</td>
                                <td><span class="badge-soft badge-soft-success">Completada</span></td>
                            </tr>
                            <tr>
                                <td>Fútbol formativo</td>
                                <td>Juvenil B</td>
                                <td>10:30 a.m.</td>
                                <td><span class="badge-soft badge-soft-info">En curso</span></td>
                            </tr>
                            <tr>
                                <td>Acondicionamiento físico</td>
                                <td>Adultos</td>
                                <td>2:00 p.m.</td>
                                <td><span class="badge-soft badge-soft-warning">Pendiente</span></td>
                            </tr>
                            <tr>
                                <td>Defensa personal</td>
                                <td>Avanzado</td>
                                <td>4:30 p.m.</td>
                                <td><span class="badge-soft badge-soft-warning">Pendiente</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card" style="margin-bottom: 20px;">
                <div class="card-header-custom">
                    <h3><i class="fa fa-lightbulb"></i> Resumen docente</h3>
                </div>

                <ul class="dashboard-alert-list">
                    <li>
                        <i class="fa fa-users"></i>
                        La asistencia del grupo se mantiene estable esta semana.
                    </li>
                    <li>
                        <i class="fa fa-check"></i>
                        Las evaluaciones registradas están al día.
                    </li>
                    <li>
                        <i class="fa fa-clock"></i>
                        Aún hay 2 clases pendientes por impartir hoy.
                    </li>
                </ul>
            </div>

            <div class="dashboard-card">
                <div class="card-header-custom">
                    <h3><i class="fa fa-bolt"></i> Acciones rápidas</h3>
                </div>

                <div class="quick-actions">
                    <button class="dashboard-mini-btn" onclick="mostrarVista('dashboard-profesor-dashboard')">
                        <i class="fa fa-chart-bar"></i> Ver dashboard
                    </button>

                    <button class="dashboard-mini-btn" onclick="mostrarVista('dashboard-profesor')">
                        <i class="fa fa-arrow-left"></i> Volver
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>