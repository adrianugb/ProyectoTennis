@model ProyectoGrupalTennis.Models.NotificacionesProfesorViewModel

<div class="module-block">
    <h1 class="module-title">Notificaciones - Profesor</h1>
    <p class="module-subtitle">Avisos relacionados con tus cursos, horarios y clases.</p>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success">@TempData["MensajeExito"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-responsive" style="margin-top:25px;">
        <table class="table report-table">
            <thead>
                <tr>
                    <th>Notificación</th>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th style="text-align:center;">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Notificaciones.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            No tenés notificaciones registradas.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var n in Model.Notificaciones)
                    {
                        <tr class="@(n.Leida ? "" : "fw-bold")">
                            <td>
                                <i class="fa @n.Icono" style="color:@n.Color;margin-right:6px;"></i>
                                @n.Titulo
                            </td>
                            <td>@n.Mensaje</td>
                            <td>@n.FechaEnvio.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (n.Leida)
                                {
                                    <span class="badge-soft-success">Leída</span>
                                }
                                else
                                {
                                    <span class="badge-soft-warning">Nueva</span>
                                }
                            </td>
                            <td style="text-align:center;">
                                @if (!n.Leida)
                                {
                                    <form asp-controller="PerfilProfesor"
                                          asp-action="MarcarNotificacionLeida"
                                          method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idNotificacion" value="@n.IdNotificacion" />
                                        <button type="submit" class="module-btn">
                                            Marcar leída
                                        </button>
                                    </form>
                                }
                                <form asp-controller="PerfilProfesor"
                                      asp-action="EliminarNotificacion"
                                      method="post" style="display:inline;"
                                      onsubmit="return confirm('¿Eliminar esta notificación?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="idNotificacion" value="@n.IdNotificacion" />
                                    <button type="submit" class="module-btn" style="background:#c0392b;">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
