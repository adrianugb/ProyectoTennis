@{
    ViewData["Title"] = "Notificaciones";
}

<div class="container" style="padding: 40px 0;">
    <div class="dashboard-block">
        <h1 class="page-title">Notificaciones Automáticas</h1>
        <p class="page-subtitle">
            Acceda al panel de notificaciones correspondiente a su perfil.
        </p>

        <div class="action-buttons" style="margin-bottom: 10px; display:flex; flex-wrap:wrap; gap:10px;">
            <a href="/Home/Index" class="dashboard-mini-btn">Volver al inicio</a>

            @if (User.IsInRole("Administrador"))
            {
                <a asp-controller="Home"
                   asp-action="Notificaciones"
                   class="dashboard-mini-btn">
                    Administrador
                </a>
            }

            @if (User.IsInRole("Profesor"))
            {
                <a asp-controller="Home"
                   asp-action="Notificaciones"
                   class="dashboard-mini-btn">
                    Profesor
                </a>
            }

            @if (User.IsInRole("Usuario"))
            {
                <a asp-controller="Usuario"
                   asp-action="Notificaciones"
                   class="dashboard-mini-btn">
                    Usuario
                </a>
            }
        </div>
    </div>

    @if (User.IsInRole("Administrador"))
    {
        <div class="vista-notificaciones" style="margin-top: 30px;">
            @await Html.PartialAsync("~/Views/Notificaciones/_NotificacionesAdmin.cshtml")
        </div>
    }
    else if (User.IsInRole("Profesor"))
    {
        <div class="vista-notificaciones" style="margin-top: 30px;">
            @await Html.PartialAsync("~/Views/Notificaciones/_NotificacionesProfesor.cshtml")
        </div>
    }
</div>