@model List<ProyectoGrupalTennis.Models.ViewModels.UsuarioRolViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <!-- HEADER -->
            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Usuarios</h1>

                    <p class="perfil-subtitle">
                        Administración general de usuarios, roles y accesos del sistema.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-users"></i> Gestión de Usuarios
                </div>
            </div>

            <!-- TABLA -->
            <div class="perfil-table-block">

                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">
                        Usuarios registrados
                    </h2>
                </div>

                <!-- FILTROS -->
                <div class="perfil-filter-row">

                    <input type="text"
                           id="filtroNombre"
                           class="form-control"
                           placeholder="Buscar usuario..."
                           oninput="filtrarTabla()" />

                    <select id="filtroRol"
                            class="form-select"
                            onchange="filtrarTabla()">

                        <option value="">Filtrar por rol</option>
                        <option value="Administrador">Administrador</option>
                        <option value="Profesor">Profesor</option>
                        <option value="Usuario">Usuario</option>

                    </select>

                </div>

                <!-- TABLA -->
                <div class="table-responsive">

                    <table class="perfil-table" id="tablaUsuarios">

                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>Correo</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Fecha Registro</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">

                                        <i class="fa fa-users fa-2x mb-2 d-block"></i>

                                        No hay usuarios registrados.

                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    var usuario = item.Usuario;
                                    var rol = item.Rol;

                                    <tr>

                                        <td>
                                            @usuario.Nombre @usuario.Apellido
                                        </td>

                                        <td>
                                            @usuario.Email
                                        </td>

                                        <td>

                                            @if (rol == "Administrador")
                                            {
                                                <span class="perfil-badge-success">
                                                    Administrador
                                                </span>
                                            }
                                            else if (rol == "Profesor")
                                            {
                                                <span class="perfil-badge-warning">
                                                    Profesor
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge">
                                                    Usuario
                                                </span>
                                            }

                                        </td>

                                        <td>

                                            @if (usuario.Bloqueado)
                                            {
                                                <span class="perfil-badge-danger">
                                                    Bloqueado
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-success">
                                                    Activo
                                                </span>
                                            }

                                        </td>

                                        <td>
                                            @usuario.FechaRegistro.ToString("dd/MM/yyyy")
                                        </td>

                                        <td class="d-flex flex-wrap gap-2">

                                            @if (usuario.Email != "admin@tennis.com")
                                            {
                                                <!-- CAMBIAR ROL -->
                                                <button type="button" class="perfil-action-link border-0 bg-transparent"
                                                        onclick="abrirModalRol('@usuario.Id',
                                                    '@usuario.Nombre @usuario.Apellido',
                                                    '@rol')">

                                                    Cambiar Rol

                                                </button>

                                                <!-- BLOQUEAR -->
                                                @if (!usuario.Bloqueado)
                                                {
                                                    <a asp-action="BloquearUsuario"
                                                           asp-route-id="@usuario.Id"
                                                           class="perfil-action-link text-danger">

                                                        Bloquear

                                                    </a>
                                                }
                                                else
                                                {
                                                    <a asp-action="DesbloquearUsuario"
                                                           asp-route-id="@usuario.Id"
                                                           class="perfil-action-link text-success">

                                                        Desbloquear

                                                    </a>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">
                                                    Administrador Principal
                                                </span>
                                            }

                                        </td>

                                    </tr>
                                }
                            }

                        </tbody>

                    </table>

                </div>
            </div>
        </div>
    </div>
</section>

<!-- MODAL CAMBIAR ROL -->
<div class="modal fade"
     id="modalRol"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog">

        <div class="modal-content">

            <form asp-controller="Admin"
                  asp-action="CambiarRol"
                  method="post">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Cambiar Rol
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body">

                    <input type="hidden"
                           id="usuarioIdRol"
                           name="id" />

                    <div class="mb-3">

                        <label class="form-label">
                            Usuario
                        </label>

                        <input type="text"
                               id="nombreUsuarioRol"
                               class="form-control"
                               readonly />

                    </div>

                    <div class="mb-3">

                        <label class="form-label">
                            Rol
                        </label>

                        <select class="form-select"
                                name="nuevoRol"
                                id="nuevoRol">

                            <option value="Usuario">
                                Usuario
                            </option>

                            <option value="Profesor">
                                Profesor
                            </option>

                            <option value="Administrador">
                                Administrador
                            </option>

                        </select>

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        Cancelar

                    </button>

                    <button type="submit"
                            class="btn btn-primary">

                        Guardar

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        function filtrarTabla() {

            const textoBuscar =
                document.getElementById('filtroNombre')
                .value
                .toLowerCase();

            const rolFiltro =
                document.getElementById('filtroRol')
                .value;

            const filas =
                document.querySelectorAll('#tablaUsuarios tbody tr');

            filas.forEach(fila => {

                const nombre =
                    fila.cells[0]?.textContent.toLowerCase() ?? '';

                const rol =
                    fila.cells[2]?.textContent.trim() ?? '';

                const coincideNombre =
                    nombre.includes(textoBuscar);

                const coincideRol =
                    !rolFiltro || rol.includes(rolFiltro);

                fila.style.display =
                    coincideNombre && coincideRol
                        ? ''
                        : 'none';

            });
        }

        function abrirModalRol(id, nombre, rolActual)
        {
            $('#usuarioIdRol').val(id);

            $('#nombreUsuarioRol').val(nombre);

            $('#nuevoRol').val(rolActual);

            $('#modalRol').modal('show');
        }


    </script>

}
