<div class="dashboard-block">
    <h1 class="page-title">Configuración de Geolocalización</h1>
    <p class="page-subtitle">Define zonas de cobertura, tarifas y asigna rutas a profesores.</p>

    <div class="row">
        <div class="col-md-8">
            <div style="border-radius:14px;overflow:hidden;border:1px solid #f1f1f1;box-shadow:0 8px 22px rgba(0,0,0,0.08);margin-bottom:20px;">
                <div style="padding:14px 18px;border-bottom:1px solid #f1f1f1;display:flex;justify-content:space-between;align-items:center;background:#fff;">
                    <strong style="font-size:15px;font-weight:700;color:#252525;">
                        <i class="fa fa-map" style="color:#a5c422;"></i> Mapa de Cobertura — Academia Muñoz Tennis
                    </strong>
                    <div style="display:flex;gap:8px;">
                        <button class="dashboard-mini-btn" style="padding:7px 13px;font-size:12px;background:#757575;">
                            <i class="fa fa-map-marker"></i> Academia
                        </button>
                        <button class="dashboard-mini-btn" style="padding:7px 13px;font-size:12px;">
                            <i class="fa fa-plus"></i> Zona
                        </button>
                    </div>
                </div>
                <div style="background:linear-gradient(135deg,#c8e6c9 0%,#a5d6a7 50%,#81c784 100%);min-height:360px;position:relative;overflow:hidden;">
                    <div style="position:absolute;inset:0;background-image:linear-gradient(90deg,rgba(255,255,255,.28) 1px,transparent 1px),linear-gradient(0deg,rgba(255,255,255,.28) 1px,transparent 1px);background-size:55px 55px;"></div>
                    <div style="position:absolute;background:rgba(255,255,255,.55);height:6px;border-radius:3px;width:100%;top:38%;"></div>
                    <div style="position:absolute;background:rgba(255,255,255,.55);height:6px;border-radius:3px;width:100%;top:65%;"></div>
                    <div style="position:absolute;background:rgba(255,255,255,.55);width:6px;border-radius:3px;height:100%;left:32%;"></div>
                    <div style="position:absolute;background:rgba(255,255,255,.55);width:6px;border-radius:3px;height:100%;left:60%;"></div>

                    <div style="position:absolute;left:42%;top:42%;width:120px;height:120px;border-radius:50%;border:2px solid #a5c422;background:rgba(165,196,34,.14);transform:translate(-50%,-50%);pointer-events:none;"></div>
                    <div style="position:absolute;left:42%;top:42%;width:240px;height:240px;border-radius:50%;border:2px solid #8eab1d;background:rgba(165,196,34,.05);transform:translate(-50%,-50%);pointer-events:none;"></div>
                    <div style="position:absolute;left:42%;top:42%;width:360px;height:360px;border-radius:50%;border:2px dashed #ccc;background:rgba(165,196,34,.02);transform:translate(-50%,-50%);pointer-events:none;"></div>

                    <div style="position:absolute;left:42%;top:42%;transform:translate(-50%,-100%);text-align:center;z-index:10;">
                        <div style="width:28px;height:28px;border-radius:50% 50% 50% 0;background:#a5c422;transform:rotate(-45deg);margin:0 auto;border:3px solid #fff;box-shadow:0 4px 10px rgba(0,0,0,.3);"></div>
                        <div style="background:#fff;border-radius:7px;padding:3px 9px;font-size:11px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.15);margin-top:6px;display:inline-block;">
                            <i class="fa fa-home"></i> Academia
                        </div>
                    </div>

                    <div style="position:absolute;left:67%;top:63%;transform:translate(-50%,-100%);text-align:center;z-index:10;">
                        <div style="width:24px;height:24px;border-radius:50% 50% 50% 0;background:#e74c3c;transform:rotate(-45deg);margin:0 auto;border:3px solid #fff;box-shadow:0 4px 10px rgba(0,0,0,.3);"></div>
                        <div style="background:#fff;border-radius:7px;padding:3px 9px;font-size:10px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.15);margin-top:6px;display:inline-block;">Alumno A</div>
                    </div>

                    <div style="position:absolute;left:25%;top:44%;transform:translate(-50%,-100%);text-align:center;z-index:10;">
                        <div style="width:24px;height:24px;border-radius:50% 50% 50% 0;background:#9c27b0;transform:rotate(-45deg);margin:0 auto;border:3px solid #fff;box-shadow:0 4px 10px rgba(0,0,0,.3);"></div>
                        <div style="background:#fff;border-radius:7px;padding:3px 9px;font-size:10px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.15);margin-top:6px;display:inline-block;">Alumno B</div>
                    </div>

                    <div style="position:absolute;left:56%;top:24%;width:34px;height:34px;border-radius:50%;background:#1976d2;color:#fff;display:flex;align-items:center;justify-content:center;border:3px solid #fff;box-shadow:0 3px 8px rgba(0,0,0,.25);z-index:10;">
                        <i class="fa fa-user" style="font-size:13px;"></i>
                    </div>
                    <div style="position:absolute;left:58%;top:18%;background:#fff;border-radius:6px;padding:3px 8px;font-size:10px;font-weight:700;box-shadow:0 2px 6px rgba(0,0,0,.15);z-index:11;">Prof. López</div>

                    <div style="position:absolute;bottom:14px;left:14px;background:rgba(255,255,255,.96);border-radius:12px;padding:12px 16px;box-shadow:0 8px 22px rgba(0,0,0,.08);z-index:20;min-width:180px;font-size:12px;">
                        <div style="font-weight:700;color:#252525;margin-bottom:8px;"><i class="fa fa-info-circle" style="color:#a5c422;"></i> Leyenda de zonas</div>
                        <div style="display:flex;flex-direction:column;gap:5px;">
                            <div style="display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border-radius:50%;background:#a5c422;display:inline-block;flex-shrink:0;"></span>0–5 km — Zona A (sin cargo)</div>
                            <div style="display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border-radius:50%;border:2px solid #8eab1d;display:inline-block;flex-shrink:0;"></span>5–10 km — Zona B (+₡6,000)</div>
                            <div style="display:flex;align-items:center;gap:8px;"><span style="width:10px;height:10px;border-radius:50%;border:2px dashed #ccc;display:inline-block;flex-shrink:0;"></span>10–15 km — Zona C (+₡12,000)</div>
                        </div>
                    </div>
                    <div style="position:absolute;top:14px;right:14px;display:flex;flex-direction:column;gap:4px;z-index:20;">
                        <button style="width:34px;height:34px;background:#fff;border:none;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.15);cursor:pointer;font-size:13px;">+</button>
                        <button style="width:34px;height:34px;background:#fff;border:none;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.15);cursor:pointer;font-size:13px;">−</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-stat-card" style="min-height:auto;padding:18px;text-align:left;margin-bottom:16px;">
                <h4 style="font-size:15px;font-weight:700;margin-bottom:14px;">
                    <i class="fa fa-sliders" style="color:#a5c422;"></i> Parámetros de Cobertura
                </h4>
                <div class="form-group">
                    <label>Radio máximo de desplazamiento (km)</label>
                    <div style="display:flex;gap:10px;align-items:center;">
                        <input type="range" min="1" max="30" value="15" style="flex:1;accent-color:#a5c422;" />
                        <strong>15 km</strong>
                    </div>
                </div>
                <div class="form-group">
                    <label>Dirección base de la academia</label>
                    <input type="text" class="form-control" value="San José, Escazú, Muñoz Tennis Academy" />
                </div>
                <button class="dashboard-mini-btn" style="width:100%;text-align:center;">
                    <i class="fa fa-save"></i> Guardar configuración
                </button>
            </div>

            <div class="dashboard-stat-card" style="min-height:auto;padding:18px;text-align:left;margin-bottom:16px;">
                <h4 style="font-size:15px;font-weight:700;margin-bottom:14px;">
                    <i class="fa fa-money" style="color:#a5c422;"></i> Tarifas por Zona
                </h4>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid #f1f1f1;border-radius:10px;">
                        <span style="width:12px;height:12px;border-radius:50%;background:#a5c422;flex-shrink:0;"></span>
                        <div style="flex:1;"><strong style="font-size:13px;">Zona A — 0–5 km</strong></div>
                        <input type="text" class="form-control" style="width:85px;padding:6px 10px;font-size:12px;" value="₡0" />
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid #f1f1f1;border-radius:10px;">
                        <span style="width:12px;height:12px;border-radius:50%;background:#f39c12;flex-shrink:0;"></span>
                        <div style="flex:1;"><strong style="font-size:13px;">Zona B — 5–10 km</strong></div>
                        <input type="text" class="form-control" style="width:85px;padding:6px 10px;font-size:12px;" value="₡1,200/km" />
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid #f1f1f1;border-radius:10px;">
                        <span style="width:12px;height:12px;border-radius:50%;background:#e74c3c;flex-shrink:0;"></span>
                        <div style="flex:1;"><strong style="font-size:13px;">Zona C — 10–15 km</strong></div>
                        <input type="text" class="form-control" style="width:85px;padding:6px 10px;font-size:12px;" value="₡1,800/km" />
                    </div>
                </div>
                <button class="dashboard-mini-btn" style="width:100%;text-align:center;margin-top:12px;">
                    <i class="fa fa-save"></i> Actualizar tarifas
                </button>
            </div>

            <div class="dashboard-stat-card" style="min-height:auto;padding:18px;text-align:left;">
                <h4 style="font-size:15px;font-weight:700;margin-bottom:12px;">
                    <i class="fa fa-map-signs" style="color:#a5c422;"></i> Clases a domicilio hoy
                </h4>
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <div style="border:1px solid #f1f1f1;border-radius:11px;padding:12px 14px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                            <strong style="font-size:13px;">Prof. López → Alumno A</strong>
                            <span style="background:#e3f2fd;color:#1565c0;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;">6.2 km</span>
                        </div>
                        <div style="font-size:12px;color:#757575;">10:00 AM · San Rafael de Escazú</div>
                        <button class="dashboard-mini-btn" style="padding:5px 12px;font-size:12px;margin-top:8px;">
                            <i class="fa fa-map"></i> Ver ruta
                        </button>
                    </div>
                    <div style="border:1px solid #f1f1f1;border-radius:11px;padding:12px 14px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                            <strong style="font-size:13px;">Prof. Torres → Alumno B</strong>
                            <span style="background:#fff4db;color:#b78103;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;">11.8 km</span>
                        </div>
                        <div style="font-size:12px;color:#757575;">2:00 PM · Santa Ana Centro</div>
                        <button class="dashboard-mini-btn" style="padding:5px 12px;font-size:12px;margin-top:8px;">
                            <i class="fa fa-map"></i> Ver ruta
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
