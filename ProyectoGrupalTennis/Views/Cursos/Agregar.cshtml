@model ProyectoGrupalTennis.Models.CursoFormViewModel
@{
    ViewData["Title"] = "Agregar Curso";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Agregar Curso</h1>
                    <p class="perfil-subtitle">Completa el formulario para registrar un nuevo curso.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-plus-circle"></i> Nuevo Curso
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Datos del curso</h2>
                    <div class="perfil-actions">
                        <a asp-controller="Curso" asp-action="Index" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                    </div>
                </div>

                <form asp-controller="Curso" asp-action="Agregar" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row" style="padding: 20px 0;">

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.Nombre">Nombre</label>
                                <input asp-for="Curso.Nombre" class="form-control"
                                       placeholder="Nombre del curso" />
                                <span asp-validation-for="Curso.Nombre" class="text-danger"
                                      style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.Nivel">Nivel</label>
                                <select asp-for="Curso.Nivel" class="form-select">
                                    <option value="">Seleccione un nivel</option>
                                    <option value="Principiante">Principiante</option>
                                    <option value="Intermedio">Intermedio</option>
                                    <option value="Avanzado">Avanzado</option>
                                </select>
                                <span asp-validation-for="Curso.Nivel" class="text-danger"
                                      style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.CuposDisponibles">Cupos disponibles</label>
                                <input asp-for="Curso.CuposDisponibles" type="number" min="0"
                                       class="form-control" placeholder="0" />
                                <span asp-validation-for="Curso.CuposDisponibles" class="text-danger"
                                      style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                Curso.IdProfesorUserId"">Profesor asignado</label>
                                <select asp-for="Curso.IdProfesorUserId" class="form-select">
                                    <option value="">Sin profesor asignado</option>
                                    @foreach (var p in Model.Profesores)
                                    {
                                        <option value="@p.Id">@p.Nombre @p.Apellidos</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="NuevoHorario.DiaSemana">Día</label>
                                <select asp-for="NuevoHorario.DiaSemana" class="form-select">
                                    <option value="">Seleccione el día</option>
                                    <option value="Lunes">Lunes</option>
                                    <option value="Martes">Martes</option>
                                    <option value="Miércoles">Miércoles</option>
                                    <option value="Jueves">Jueves</option>
                                    <option value="Viernes">Viernes</option>
                                    <option value="Sábado">Sábado</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="NuevoHorario.HoraInicio">Hora Inicio</label>
                                <input asp-for="NuevoHorario.HoraInicio" type="time" class="form-control" />
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-3">
                                <label asp-for="NuevoHorario.HoraFin">Hora Fin</label>
                                <input asp-for="NuevoHorario.HoraFin" type="time" class="form-control" />
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="mb-3">
                                <label asp-for="Curso.Descripcion">Descripción</label>
                                <textarea asp-for="Curso.Descripcion" class="form-control"
                                          placeholder="Descripción del curso"></textarea>
                                <span asp-validation-for="Curso.Descripcion" class="text-danger"
                                      style="font-size:12px;"></span>
                            </div>
                        </div>

                    </div>

                    <div class="perfil-actions" style="padding-bottom: 10px;">
                        <a asp-controller="Curso" asp-action="Index" class="perfil-btn-outline">
                            Cancelar
                        </a>
                        <button type="submit" class="perfil-btn">
                            <i class="fa fa-save"></i> Guardar curso
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}