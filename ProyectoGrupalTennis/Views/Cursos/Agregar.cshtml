@model ProyectoGrupalTennis.Models.CursoFormViewModel
@{
    ViewData["Title"] = "Crear Curso";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Crear Curso</h1>
                    <p class="perfil-subtitle">Define nombre, nivel, horario, cupos y profesor de la nueva Curso.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-plus-circle"></i> Nuevo Curso
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Datos del Curso</h2>
                    <div class="perfil-actions">
                        <a asp-controller="Curso" asp-action="Index" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                    </div>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-controller="Curso" asp-action="Agregar" method="post" id="formCurso">
                    @Html.AntiForgeryToken()

                    <div class="row" style="padding: 20px 0;">

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.Nombre">Nombre</label>
                                <input asp-for="Curso.Nombre" class="form-control" placeholder="Nombre de la Curso" />
                                <span asp-validation-for="Curso.Nombre" class="text-danger" style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.Nivel">Nivel</label>
                                <select asp-for="Curso.Nivel" class="form-select">
                                    <option value="">Seleccione un nivel</option>
                                    <option value="Principiante">Principiante</option>
                                    <option value="Intermedio">Intermedio</option>
                                    <option value="Avanzado">Avanzado</option>
                                </select>
                                <span asp-validation-for="Curso.Nivel" class="text-danger" style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.CuposDisponibles">Cupos disponibles</label>
                                <input asp-for="Curso.CuposDisponibles" type="number" min="0"
                                       class="form-control" placeholder="0" />
                                <span asp-validation-for="Curso.CuposDisponibles" class="text-danger" style="font-size:12px;"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Curso.IdProfesor">Profesor asignado</label>
                                <select asp-for="Curso.IdProfesor" class="form-select">
                                    <option value="">Sin profesor asignado</option>
                                    @foreach (var p in Model.Profesores)
                                    {
                                        <option value="@p.Id">@p.Nombre @p.Apellidos</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="mb-3">
                                <label asp-for="Curso.Descripcion">Descripción</label>
                                <textarea asp-for="Curso.Descripcion" class="form-control"
                                          placeholder="Descripción de la Curso"></textarea>
                            </div>
                        </div>

                        <!-- HORARIOS -->
                        <div class="col-md-12">
                            <label style="margin-bottom: 10px;">Horarios</label>
                            <div id="horariosContainer">
                                @for (int i = 0; i < Model.Horarios.Count; i++)
                                {
                                    <div class="row horario-row" style="margin-bottom: 10px;">
                                        <div class="col-md-4">
                                            <select name="Horarios[@i].DiaSemana" class="form-select">
                                                <option value="">Día</option>
                                                <option value="Lunes">Lunes</option>
                                                <option value="Martes">Martes</option>
                                                <option value="Miércoles">Miércoles</option>
                                                <option value="Jueves">Jueves</option>
                                                <option value="Viernes">Viernes</option>
                                                <option value="Sábado">Sábado</option>
                                                <option value="Domingo">Domingo</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <input type="time" name="Horarios[@i].HoraInicio" class="form-control" />
                                        </div>
                                        <div class="col-md-3">
                                            <input type="time" name="Horarios[@i].HoraFin" class="form-control" />
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" class="btn btn-outline-danger btn-eliminar-horario">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                            <button type="button" id="btnAgregarHorario" class="perfil-btn-outline" style="margin-top: 10px;">
                                <i class="fa fa-plus"></i> Agregar horario
                            </button>
                        </div>

                    </div>

                    <div class="perfil-actions" style="padding-bottom: 10px;">
                        <a asp-controller="Curso" asp-action="Index" class="perfil-btn-outline">Cancelar</a>
                        <button type="submit" class="perfil-btn">
                            <i class="fa fa-save"></i> Guardar Curso
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let horarioIndex = @Model.Horarios.Count;

        document.getElementById('btnAgregarHorario').addEventListener('click', function () {
            const container = document.getElementById('horariosContainer');
            const div = document.createElement('div');
            div.className = 'row horario-row';
            div.style.marginBottom = '10px';
            div.innerHTML = `
                <div class="col-md-4">
                    <select name="Horarios[${horarioIndex}].DiaSemana" class="form-select">
                        <option value="">Día</option>
                        <option value="Lunes">Lunes</option>
                        <option value="Martes">Martes</option>
                        <option value="Miércoles">Miércoles</option>
                        <option value="Jueves">Jueves</option>
                        <option value="Viernes">Viernes</option>
                        <option value="Sábado">Sábado</option>
                        <option value="Domingo">Domingo</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="time" name="Horarios[${horarioIndex}].HoraInicio" class="form-control" />
                </div>
                <div class="col-md-3">
                    <input type="time" name="Horarios[${horarioIndex}].HoraFin" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-outline-danger btn-eliminar-horario">
                        <i class="fa fa-trash"></i>
                    </button>
                </div>
            `;
            container.appendChild(div);
            horarioIndex++;
        });

        document.addEventListener('click', function (e) {
            if (e.target.closest('.btn-eliminar-horario')) {
                e.target.closest('.horario-row').remove();
            }
        });
    </script>
}
}
}
