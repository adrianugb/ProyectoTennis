<div class="module-block">
    <h1 class="module-title">Registrar Métricas</h1>
    <p class="module-subtitle">
        Formulario visual para registrar el desempeño técnico del alumno.
    </p>

    <div class="row" style="margin-bottom: 15px;">
        <div class="col-md-6">
            <input type="text" class="form-control" placeholder="Nombre del alumno" />
        </div>

        <div class="col-md-6">
            <select class="form-control">
                <option>Clase más reciente</option>
                <option>Sesión especial</option>
            </select>
        </div>
    </div>

    <div class="row" style="margin-bottom: 15px;">
        <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Forehand (%)" />
        </div>

        <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Backhand (%)" />
        </div>

        <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Saque (%)" />
        </div>

        <div class="col-md-3">
            <input type="number" class="form-control" placeholder="Desplazamiento (%)" />
        </div>
    </div>

    <div style="margin-bottom: 20px;">
        <textarea class="form-control" rows="5" placeholder="Observaciones del profesor"></textarea>
    </div>

    <div class="module-actions">
        <button class="module-btn">Guardar métricas</button>
        <button class="module-btn" onclick="mostrarVista('progreso-profesor')">Volver</button>
    </div>
</div>