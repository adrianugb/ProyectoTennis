@model List<AcademiaTennisDAL.Entities.Profesor>
@{
    ViewData["Title"] = "Gestión de Profesores";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Profesores</h1>
                    <p class="perfil-subtitle">Consulta y administra la información de los profesores.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-user"></i> Administración de Profesores
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de profesores</h2>
                    <div class="perfil-actions">
                        <a asp-controller="Home" asp-action="PerfilAdmin" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                        <a asp-controller="Profesor" asp-action="Agregar" class="perfil-btn">
                            <i class="fa fa-plus"></i> Agregar profesor
                        </a>
                    </div>
                </div>

                <form method="get" asp-action="Index">
                    <div class="perfil-filter-row">
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar profesor..."
                               value="@Context.Request.Query["buscar"]" />

                        <select name="especialidad" class="form-select">
                            <option value="">Filtrar por especialidad</option>
                            <option>Técnica básica</option>
                            <option>Técnica avanzada</option>
                            <option>Entrenamiento funcional</option>
                        </select>

                        <select name="estado" class="form-select">
                            <option value="">Filtrar por estado</option>
                            <option>Activo</option>
                            <option>Inactivo</option>
                        </select>

                        <button type="submit" class="perfil-btn">Buscar</button>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Teléfono</th>
                                <th>Especialidad</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td>PROF-@p.Id.ToString("D3")</td>
                                    <td>@p.Nombre @p.Apellidos</td>
                                    <td>@p.Email</td>
                                    <td>@p.Telefono</td>
                                    <td>@p.Especialidad</td>
                                    <td>
                                        @if (p.Activo)
                                        {
                                            <span class="perfil-badge-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="perfil-badge-warning">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Profesor" asp-action="Editar"
                                           asp-route-id="@p.Id" class="perfil-action-link">Editar</a>
                                        <span class="perfil-action-separator">|</span>
                                        <form asp-controller="Profesor" asp-action="CambiarEstado"
                                              method="post" style="display:inline">
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <input type="hidden" name="activo" value="@(!p.Activo)" />
                                            <button type="submit" class="perfil-action-link"
                                                    style="background:none;border:none;padding:0;cursor:pointer;">
                                                @(p.Activo ? "Desactivar" : "Activar")
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>