@model AcademiaTennisDAL.Entities.TipoClase

@{
    ViewData["Title"] = "Editar Tipo de Clase";
}

<link rel="stylesheet"
      href="~/css/perfiles.css"
      asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">
                        Editar Tipo de Clase
                    </h1>

                    <p class="perfil-subtitle">
                        Modifica el nombre, la descripción o el estado
                        de la modalidad seleccionada.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-pen"></i>
                    Actualizar Tipo de Clase
                </div>
            </div>

            <div class="perfil-table-block">

                <form asp-controller="AdminCatalogoCursos"
                      asp-action="EditarTipoClase"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input asp-for="IdTipoClase"
                           type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="Nombre"
                                   class="form-label">
                                Nombre del tipo de clase
                            </label>

                            <input asp-for="Nombre"
                                   class="form-control" />

                            <span asp-validation-for="Nombre"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">
                                Estado
                            </label>

                            <div class="form-check mt-2">
                                <input asp-for="Activo"
                                       class="form-check-input" />

                                <label asp-for="Activo"
                                       class="form-check-label">
                                    Tipo de clase activo
                                </label>
                            </div>

                            <small class="text-muted">
                                Si se desactiva, dejará de aparecer
                                en formularios nuevos, pero no se eliminará
                                del historial.
                            </small>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion"
                                   class="form-label">
                                Descripción
                            </label>

                            <textarea asp-for="Descripcion"
                                      class="form-control"
                                      rows="4"></textarea>

                            <span asp-validation-for="Descripcion"
                                  class="text-danger">
                            </span>
                        </div>

                    </div>

                    <div class="perfil-actions mt-4">

                        <a asp-controller="AdminCatalogoCursos"
                           asp-action="Index"
                           class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i>
                            Cancelar
                        </a>

                        <button type="submit"
                                class="perfil-btn">
                            <i class="fa fa-save"></i>
                            Guardar Cambios
                        </button>

                    </div>

                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}