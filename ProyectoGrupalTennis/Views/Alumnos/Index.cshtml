@model List<AcademiaTennisDAL.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Gestión de Alumnos";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Gestión de Alumnos</h1>
                    <p class="perfil-subtitle">Consulta y administra la información de los alumnos.</p>
                </div>
                <div class="perfil-badge">
                    <i class="fa fa-user-graduate"></i> Administración de Alumnos
                </div>
            </div>

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de alumnos</h2>
                    <div class="perfil-actions">
                        <a asp-controller="Home" asp-action="PerfilAdmin" class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i> Regresar
                        </a>
                        <a asp-controller="Alumnos" asp-action="Agregar" class="perfil-btn">
                            <i class="fa fa-plus"></i> Agregar alumno
                        </a>
                    </div>
                </div>

                <form method="get" asp-action="Index">
                    <div class="perfil-filter-row">
                        <input type="text" name="buscar" class="form-control"
                               placeholder="Buscar alumno..."
                               value="@Context.Request.Query["buscar"]" />
                        <select name="estado" class="form-select">
                            <option value="">Filtrar por estado</option>
                            @if (Context.Request.Query["estado"] == "Activo")
                            {
                                <option value="Activo" selected>Activo</option>
                            }
                            else
                            {
                                <option value="Activo">Activo</option>
                            }
                            @if (Context.Request.Query["estado"] == "Inactivo")
                            {
                                <option value="Inactivo" selected>Inactivo</option>
                            }
                            else
                            {
                                <option value="Inactivo">Inactivo</option>
                            }
                        </select>
                        <button type="submit" class="perfil-btn">Buscar</button>
                    </div>
                </form>

                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                        <i class="fa fa-check-circle me-2"></i> @ViewBag.Mensaje
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Teléfono</th>
                                <th>Fecha Registro</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fa fa-users fa-2x mb-2 d-block"></i>
                                        No hay alumnos registrados en el sistema.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var a in Model)
                                {
                                    <tr>
                                        <td>@a.Nombre @a.Apellido</td>
                                        <td>@a.Email</td>
                                        <td>@(a.PhoneNumber ?? "No registrado")</td>
                                        <td>@a.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            @if (!a.Bloqueado)
                                            {
                                                <span class="perfil-badge-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-warning">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="Alumnos" asp-action="Editar"
                                               asp-route-id="@a.Id" class="perfil-action-link">Editar</a>
                                            <span class="perfil-action-separator">|</span>
                                            <form asp-controller="Alumnos" asp-action="CambiarEstado"
                                                  method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@a.Id" />
                                                <input type="hidden" name="activo" value="@a.Bloqueado" />
                                                <button type="submit" class="perfil-action-link"
                                                        style="background:none;border:none;padding:0;cursor:pointer;">
                                                    @(!a.Bloqueado ? "Desactivar" : "Activar")
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>