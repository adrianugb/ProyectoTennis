@section Scripts {
<script>
    (function () {
        var canvas = document.getElementById('retTendenciaChart');
        if (!canvas) return;
        new Chart(canvas.getContext('2d'), {
            type: 'line',
            data: {
                labels: ['Nov', 'Dic', 'Ene', 'Feb', 'Mar', 'Abr'],
                datasets: [
                    {
                        label: 'Retención (%)',
                        data: [91, 90, 89, 88, 86, 84],
                        borderColor: '#a5c422',
                        backgroundColor: 'rgba(165,196,34,0.08)',
                        borderWidth: 2.5,
                        pointBackgroundColor: '#a5c422',
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.35
                    },
                    {
                        label: 'Meta (%)',
                        data: [90, 90, 90, 90, 90, 90],
                        borderColor: '#cccccc',
                        borderWidth: 1.5,
                        borderDash: [6, 4],
                        pointRadius: 0,
                        fill: false,
                        tension: 0
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function (ctx) {
                                return ctx.dataset.label + ': ' + Math.round(ctx.raw) + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        min: 78, max: 95,
                        ticks: {
                            callback: function (v) { return v + '%'; },
                            font: { size: 11 },
                            color: '#aaa'
                        },
                        grid: { color: '#f0f0f0' }
                    },
                    x: {
                        ticks: { font: { size: 11 }, color: '#aaa', autoSkip: false },
                        grid: { display: false }
                    }
                }
            }
        });
    })();
</script>
}
