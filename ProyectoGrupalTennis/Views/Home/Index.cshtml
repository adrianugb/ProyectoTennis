@{
    ViewData["Title"] = "Inicio";
}




<!-- HOME -->
<section id="home" class="slider" data-stellar-background-ratio="0.5">
    <div class="container">
        <div class="row">


            <div class="owl-carousel owl-theme">

                
                <div class="item item-first">
                    <div class="caption">
                        <div class="col-md-offset-1 col-md-10">
                            <h1>Conoce nuestras clases</h1>
                            <p>Elegí la clase que te guste mas y disfrutá de una sesión interactiva</p>

                            <a href="#team" class="btn btn-success">
                                Nuestras Clases
                            </a>
                        </div>
                    </div>
                </div>
                <div class="item item-second">
                    <div class="caption">
                        <div class="slider-txt">
                            <h1>Gestiona tu Academia de Tennis</h1>
                            <p>Clases, reservas, pagos y seguimiento en un solo lugar</p>

                            <div class="d-flex gap-3 justify-content-center mt-4">
                                <a href="/Home/Login" class="btn btn-success px-4 py-2 fw-bold">
                                    Iniciar sesión
                                </a>

                                <a href="/Home/Registro" class="btn btn-register px-4 py-2 fw-bold">
                                    Registrarse
                                </a>

                         
                            </div>
                        </div>
                    </div>
                </div>
           


                <div class="item item-third">
                    <div class="caption">
                        <div class="col-md-offset-1 col-md-10">
                            <h1>Optimiza tu rendimiento</h1>
                            <p>Profesores y alumnos conectados con seguimiento en tiempo real</p>

                            <a href="/Home/Registro" class="btn btn-register px-4 py-2 fw-bold">
                                Crear cuenta
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


<!-- ABOUT -->
<section id="about">
    @await Html.PartialAsync("~/Views/Shared/_AboutUs.cshtml")
</section>

<!-- CLASES -->
<section id="team" data-stellar-background-ratio="1">
    <div class="container">
        <section id="team" data-stellar-background-ratio="1">
    <div class="container">
        <div class="row">

            <div class="col-md-12 col-sm-12">
                <div class="about-info text-center">
                    <h2 class="wow fadeInUp" data-wow-delay="0.1s">Nuestras Clases</h2>
                    <p class="wow fadeInUp" data-wow-delay="0.2s">
                        Conoce nuestras modalidades de entrenamiento y elige la que mejor se adapte a ti.
                    </p>
                </div>
            </div>

            <div class="clearfix"></div>

            <!-- Clases Regulares -->
            <div class="col-md-4 col-sm-6">
                <div class="team-thumb wow fadeInUp" data-wow-delay="0.2s">
                    <img src="~/images/clases-regulares.jpg" />

                    <div class="team-info">
                        <h3>Clases Regulares</h3>
                        <p>Clases semanales estructuradas para avanzar desde nivel básico hasta avanzado.</p>

                        <div class="team-contact-info">
                            <p><i class="fa fa-clock-o"></i> 55 minutos • Matrícula anual requerida</p>
                        </div>

                        <a href="/Home/DetalleClaseRegular" class="btn btn-success btn-sm">
                            Ver más información
                        </a>
                    </div>
                </div>
            </div>

            <!-- Clases Esporádicas -->
            <div class="col-md-4 col-sm-6">
                <div class="team-thumb wow fadeInUp" data-wow-delay="0.4s">
                    <img src="~/images/clases-esporadicas.jpg" class="img-responsive" alt="Clases Esporádicas">

                    <div class="team-info">
                        <h3>Clases Esporádicas</h3>
                        <p>Clases flexibles con reservación previa para entrenar cuando el alumno lo desee.</p>

                        <div class="team-contact-info">
                            <p><i class="fa fa-clock-o"></i> 55 minutos • Sin matrícula anual</p>
                        </div>

                        <a href="/Home/DetalleClaseEsporadica" class="btn btn-success btn-sm">
                            Ver más información
                        </a>
                    </div>
                </div>
            </div>

            <!-- Curso Intensivo -->
            <div class="col-md-4 col-sm-6">
                <div class="team-thumb wow fadeInUp" data-wow-delay="0.6s">
                    <img src="~/images/curso-intensivo.jpg" class="img-responsive" alt="Curso Intensivo">

                    <div class="team-info">
                        <h3>Curso Intensivo</h3>
                        <p>Paquete de 10 lecciones en un máximo de 2 semanas, según el nivel del alumno.</p>

                        <div class="team-contact-info">
                            <p><i class="fa fa-clock-o"></i> 10 sesiones • 55 min c/u • Sin matrícula</p>
                        </div>

                        <a href="/Home/DetalleCursoIntensivo" class="btn btn-success btn-sm">
                            Ver más información
                        </a>
                    </div>
                </div>
            </div>

            <!-- Resto de clases (mantener las entradas existentes) -->
            <div class="col-md-4 col-sm-6">
                <div class="team-thumb wow fadeInUp" data-wow-delay="0.8s">
                    <img src="~/images/clases-especificas.jpg" class="img-responsive" alt="Clases Específicas">

                    <div class="team-info">
                        <h3>Clases Específicas</h3>
                        <p>Entrenamientos enfocados en reforzar técnicas o mejorar un tema puntual.</p>

                        <div class="team-contact-info">
                            <p><i class="fa fa-clock-o"></i> 55 minutos • Horarios a convenir</p>
                        </div>

                        <a href="/Home/DetalleClaseEspecifica" class="btn btn-success btn-sm">
                            Ver más información
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 col-sm-6">
                <div class="team-thumb wow fadeInUp" data-wow-delay="1s">
                    <img src="~/images/clases-domicilio.jpg" class="img-responsive" alt="Clases a Domicilio">

                    <div class="team-info">
                        <h3>Clases a Domicilio</h3>
                        <p>Entrenamiento en la residencia del alumno si cuenta con cancha de tenis.</p>

                        <div class="team-contact-info">
                            <p><i class="fa fa-clock-o"></i> 55 minutos • Sin matrícula anual</p>
                        </div>

                        <a href="/Home/DetalleClaseDomicilio" class="btn btn-success btn-sm">
                            Ver más información
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 col-sm-6">
                <div class="team-thumb wow fadeInUp" data-wow-delay="1.2s">
                    <img src="~/images/paquete-empresarial.jpg" class="img-responsive" alt="Paquete Empresarial">

                    <div class="team-info">
                        <h3>Paquete Empresarial</h3>
                        <p>Planes personalizados para empresas interesadas en actividades para sus colaboradores.</p>

                        <div class="team-contact-info">
                            <p><i class="fa fa-clock-o"></i> 55 minutos • Plan personalizado</p>
                        </div>

                        <a href="/Home/DetallePaqueteEmpresarial" class="btn btn-success btn-sm">
                            Ver más información
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- CAMPEONATOS (integrado en el Index) -->
<section id="campeonatos" style="padding-top:60px; padding-bottom:60px; background:#f7fbf6;">
    <div class="container">
        <div class="dashboard-header" style="margin-bottom:18px;">
            <div>
                <h1 class="module-title">Campeonatos</h1>
                <p class="module-subtitle">Gestión visual de torneos, inscripciones y seguimiento de jugadores.</p>
            </div>
            <div class="dashboard-status-badge">
                <i class="fa fa-trophy"></i> Torneos
            </div>
        </div>

        <div class="row" style="gap:18px;">
            <div class="col-md-7">
                <div class="perfil-table-block">
                    <div class="perfil-table-header">
                        <h2 class="perfil-table-title">Campeonatos próximos</h2>

                        <div class="perfil-actions">
                            <a href="#" class="perfil-btn">
                                <i class="fa fa-plus"></i> Nuevo campeonato
                            </a>
                            <a href="#" class="perfil-btn-outline">
                                Exportar resultados
                            </a>
                        </div>
                    </div>
                </div>

                    <div style="margin-bottom:12px;">
                        <input type="text" class="form-control" placeholder="Buscar campeonato por nombre, fecha o categoría..." />
                    </div>
                </div>

                <!-- Review 1 -->
                <div class="col-md-4 col-sm-6">
                    <div class="review-card">
                        <span class="review-stars">★★★★★</span>

                        <p class="review-text">
                            “Las clases me han ayudado muchísimo a mejorar mi técnica.
                            Los profesores explican muy bien y las lecciones son dinámicas.”
                        </p>

                        <div class="review-user">
                            <strong>María González</strong>
                            <small>Clases Regulares</small>
                        </div>
                    </div>
                </div>

                <!-- Review 2 -->
                <div class="col-md-4 col-sm-6">
                    <div class="review-card">
                        <span class="review-stars">★★★★★</span>

                        <p class="review-text">
                            “Me encantó la flexibilidad de horarios.
                            Es ideal si no puedes asistir siempre el mismo día.”
                        </p>

                        <div class="review-user">
                            <strong>Carlos Ramírez</strong>
                            <small>Clases Esporádicas</small>
                        </div>
                    </div>
                </div>

                <!-- Review 3 -->
                <div class="col-md-4 col-sm-6">
                    <div class="review-card">
                        <span class="review-stars">★★★★★</span>

                        <p class="review-text">
                            “Excelente ambiente y profesores.
                            Se nota el seguimiento personalizado en cada clase.”
                        </p>

                        <div class="review-user">
                            <strong>Ana López</strong>
                            <small>Curso Intensivo</small>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

<!-- MAKE AN APPOINTMENT -->
    <section id="cta" data-stellar-background-ratio="1">
        <div class="container">
            <div class="row">

                <div class="col-md-12 col-sm-12 text-center">
                    <div class="section-title">
                        <h2>Empieza tu entrenamiento</h2>
                        <p>Accede al sistema o solicita más información sobre nuestras clases.</p>
                    </div>
                </div>

                <div class="col-md-6 col-sm-12">
                    <div class="cta-card text-center">
                        <h3>Reservar clases</h3>
                        <p>
                            Inicia sesión o crea una cuenta para gestionar tus clases,
                            horarios y seguimiento dentro del sistema.
                        </p>

                        <a href="/Home/Login" class="btn btn-success m-1">Iniciar sesión</a>
                        <a href="/Home/Registro" class="btn btn-default m-1">Crear cuenta</a>
                    </div>
                </div>

                <div class="col-md-6 col-sm-12">
                    <div class="contact-card">

                        <h3>Contáctanos</h3>
                        <p>Déjanos tu consulta o escríbenos directamente.</p>

                        <!-- FORM -->
                        <form>
                            <div class="form-group">
                                <input type="text" class="form-control" placeholder="Nombre">
                            </div>

                            <div class="form-group">
                                <input type="email" class="form-control" placeholder="Correo electrónico">
                            </div>

                            <div class="form-group">
                                <textarea class="form-control" rows="4" placeholder="Escribe tu mensaje"></textarea>
                            </div>

                            <!-- BOTÓN FORM -->
                            <button type="button" class="btn btn-success btn-block">
                                Enviar consulta
                            </button>
                        </form>

                        <!-- DIVISOR -->
                        <hr>

                        <p class="text-center">O contáctanos directamente:</p>

                        <!-- CONTACTO DIRECTO -->
                        <div class="contact-alt-buttons">

                            <a href="mailto:info@academiatenis.com" class="btn btn-outline-custom">
                                Correo
                            </a>

                            <a href="https://wa.me/50688888888" target="_blank" class="btn btn-whatsapp">
                                WhatsApp
                            </a>

                        </div>

                 
    </section>

<!-- LA UBICACIÓN ESTÁ AHORA EN EL FOOTER DEL _LAYOUT -->

<section class="slider">
    ...
</section>

<section class="about">
    ...
</section>
