<!-- MAKE AN APPOINTMENT -->
    <section id="cta" data-stellar-background-ratio="1">
        <div class="container">
            <div class="row">

                <div class="col-md-12 col-sm-12 text-center">
                    <div class="section-title">
                        <h2>Empieza tu entrenamiento</h2>
                        <p>Accede al sistema o solicita más información sobre nuestras clases.</p>
                    </div>
                </div>

                <div class="col-md-6 col-sm-12">
                    <div class="cta-card text-center">
                        <h3>Reservar clases</h3>
                        <p>
                            Inicia sesión o crea una cuenta para gestionar tus clases,
                            horarios y seguimiento dentro del sistema.
                        </p>

                        <a href="/Home/Login" class="btn btn-success m-1">Iniciar sesión</a>
                        <a href="/Home/Registro" class="btn btn-default m-1">Crear cuenta</a>
                    </div>
                </div>

                <div class="col-md-6 col-sm-12">
                    <div class="contact-card">

                        <h3>Contáctanos</h3>
                        <p>Déjanos tu consulta o escríbenos directamente.</p>

                        <!-- FORM -->
                        <form>
                            <div class="form-group">
                                <input type="text" class="form-control" placeholder="Nombre">
                            </div>

                            <div class="form-group">
                                <input type="email" class="form-control" placeholder="Correo electrónico">
                            </div>

                            <div class="form-group">
                                <textarea class="form-control" rows="4" placeholder="Escribe tu mensaje"></textarea>
                            </div>

                            <!-- BOTÓN FORM -->
                            <button type="button" class="btn btn-success btn-block">
                                Enviar consulta
                            </button>
                        </form>

                        <!-- DIVISOR -->
                        <hr>

                        <p class="text-center">O contáctanos directamente:</p>

                        <!-- CONTACTO DIRECTO -->
                        <div class="contact-alt-buttons">

                            <a href="mailto:info@academiatenis.com" class="btn btn-outline-custom">
                                Correo
                            </a>

                            <a href="https://wa.me/50688888888" target="_blank" class="btn btn-whatsapp">
                                WhatsApp
                            </a>

                        </div>

                 
    </section>

