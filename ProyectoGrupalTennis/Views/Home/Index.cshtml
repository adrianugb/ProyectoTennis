@{
    ViewData["Title"] = "Inicio";
}




<!-- HOME -->
<section id="home" class="slider" data-stellar-background-ratio="0.5">
    <div class="container">
        <div class="row">


            <div class="owl-carousel owl-theme">

                
                <div class="item item-first">
                    <div class="caption">
                        <div class="col-md-offset-1 col-md-10">
                            <h1>Conoce nuestras clases</h1>
                            <p>Elegí la clase que te guste mas y disfrutá de una sesión interactiva</p>

                            <a href="#team" class="btn btn-success">
                                Nuestras Clases
                            </a>
                        </div>
                    </div>
                </div>
                <div class="item item-second">
                    <div class="caption">
                        <div class="slider-txt">
                            <h1>Gestiona tu Academia de Tennis</h1>
                            <p>Clases, reservas, pagos y seguimiento en un solo lugar</p>

                            <div class="d-flex gap-3 justify-content-center mt-4">
                                <a href="/Home/Login" class="btn btn-success px-4 py-2 fw-bold">
                                    Iniciar sesión
                                </a>

                                <a href="/Home/Registro" class="btn btn-register px-4 py-2 fw-bold">
                                    Registrarse
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
           


                <div class="item item-third">
                    <div class="caption">
                        <div class="col-md-offset-1 col-md-10">
                            <h1>Optimiza tu rendimiento</h1>
                            <p>Profesores y alumnos conectados con seguimiento en tiempo real</p>

                            <a href="/Home/Registro" class="btn btn-register px-4 py-2 fw-bold">
                                Crear cuenta
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


<!-- ABOUT -->
<section id="about">
    <div class="container">
        <div class="row">

            <div class="col-md-6 col-sm-6">
                <div class="about-info">
                    <h2 class="wow fadeInUp" data-wow-delay="0.6s"> <i class="fa fa-h-square"></i>cerca de nosotros</h2>
                    <div class="wow fadeInUp" data-wow-delay="0.8s">
                        <p>La Academia de Tenis M.M.P. fue fundada en 1996 por Mario Muñoz Picado, certificado por la Professional Tennis Registry (P.T.R) como NationalTester 5 A y único profesor de la Academia de Tenis M.M.P..</p>
                        <p>La Academia está dedicada a la gestión y desarrollo del tenis en todos sus aspectos, el sistema de enseñanza permite que todos puedan aprender, disfrutar y conocer los beneficios de este deporte..</p>
                    </div>
                    <figure class="profile wow fadeInUp" data-wow-delay="1s">
                        <img src="images/author-image.jpg" class="img-responsive" alt="">
                        <figcaption>
                            <h3>Mario Muñoz Picado</h3>
                            <p>General Principal</p>
                        </figcaption>
                    </figure>
                </div>
            </div>

        </div>
    </div>
</section>


