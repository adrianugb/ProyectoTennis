@model AcademiaTennisDAL.Entities.TarifaClase

@{
    ViewData["Title"] = "Editar Tarifa";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Editar Tarifa o Paquete</h1>
                    <p class="perfil-subtitle">
                        Modifica la información y el precio de la tarifa seleccionada.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-pen"></i>
                    Actualizar Tarifa
                </div>
            </div>

            <div class="perfil-table-block">

                <form asp-controller="AdminTarifas"
                      asp-action="Editar"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input asp-for="IdTarifaClase" type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label">
                                Nombre de la tarifa
                            </label>

                            <input asp-for="Nombre"
                                   class="form-control" />

                            <span asp-validation-for="Nombre"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="IdTipoClase" class="form-label">
                                Tipo de clase
                            </label>

                            <select asp-for="IdTipoClase"
                                    asp-items="ViewBag.TiposClase"
                                    class="form-select">
                                <option value="">Seleccione una opción</option>
                            </select>

                            <span asp-validation-for="IdTipoClase"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CondicionMatricula" class="form-label">
                                Condición de matrícula
                            </label>

                            <select asp-for="CondicionMatricula"
                                    class="form-select">
                                <option value="">Seleccione una opción</option>
                                <option value="Con matrícula">
                                    Con matrícula
                                </option>
                                <option value="Sin matrícula">
                                    Sin matrícula
                                </option>
                            </select>

                            <span asp-validation-for="CondicionMatricula"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CantidadLecciones" class="form-label">
                                Cantidad de lecciones
                            </label>

                            <input asp-for="CantidadLecciones"
                                   type="number"
                                   min="1"
                                   class="form-control" />

                            <span asp-validation-for="CantidadLecciones"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Precio" class="form-label">
                                Precio
                            </label>

                            <input asp-for="Precio"
                                   type="number"
                                   min="0.01"
                                   step="0.01"
                                   class="form-control" />

                            <span asp-validation-for="Precio"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="PrecioPorPersona"
                                       class="form-check-input" />

                                <label asp-for="PrecioPorPersona"
                                       class="form-check-label">
                                    El precio es por persona
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label">
                                Descripción
                            </label>

                            <textarea asp-for="Descripcion"
                                      class="form-control"
                                      rows="4"></textarea>

                            <span asp-validation-for="Descripcion"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Activa"
                                       class="form-check-input" />

                                <label asp-for="Activa"
                                       class="form-check-label">
                                    Tarifa activa
                                </label>
                            </div>
                        </div>

                    </div>

                    <div class="perfil-actions mt-4">

                        <a asp-controller="AdminTarifas"
                           asp-action="Index"
                           class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i>
                            Cancelar
                        </a>

                        <button type="submit" class="perfil-btn">
                            <i class="fa fa-save"></i>
                            Guardar Cambios
                        </button>

                    </div>

                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}