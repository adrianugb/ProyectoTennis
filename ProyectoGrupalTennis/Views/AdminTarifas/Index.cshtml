@model List<AcademiaTennisDAL.Entities.TarifaClase>

@{
    ViewData["Title"] = "Gestión de Tarifas";
}

<link rel="stylesheet" href="~/css/perfiles.css" asp-append-version="true" />

<section class="perfil-page compact">
    <div class="container">
        <div class="perfil-container">

            <div class="perfil-header">
                <div>
                    <h1 class="perfil-title">Tarifas y Paquetes</h1>
                    <p class="perfil-subtitle">
                        Consulta y administra precios de clases individuales, en pareja,  grupales y paquetes bajo solicitud.
                    </p>
                </div>

                <div class="perfil-badge">
                    <i class="fa fa-dollar-sign"></i>
                    Administración de Tarifas
                </div>
            </div>

            
            <div class="alert alert-warning mt-3 mb-4">
                <i class="fa fa-exclamation-triangle me-2"></i>
                <strong>Importante:</strong>
                Una tarifa o paquete solo será visible para los alumnos cuando tanto la tarifa como su tipo de clase se encuentren activos.
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            <div class="perfil-table-block">
                <div class="perfil-table-header">
                    <h2 class="perfil-table-title">Listado de Tarifas</h2>

                    <div class="perfil-actions">
                        <a asp-controller="Home"
                           asp-action="PerfilAdmin"
                           class="perfil-btn-outline">
                            <i class="fa fa-arrow-left"></i>
                            Regresar
                        </a>

                        <a asp-controller="AdminTarifas"
                           asp-action="Agregar"
                           class="perfil-btn">
                            <i class="fa fa-plus"></i>
                            Crear Tarifa
                        </a>
                    </div>
                </div>

                <form method="get" asp-action="Index">
                    <div class="perfil-filter-row">

                        <input type="text"
                               name="buscar"
                               class="form-control"
                               placeholder="Buscar tarifa..."
                               value="@Context.Request.Query["buscar"]" />

                        <select name="idTipoClase"
                                asp-items="ViewBag.TiposClase"
                                class="form-select">
                            <option value="">Filtrar por tipo de clase</option>
                        </select>

                        <select name="estado" class="form-select">
                            <option value="">Filtrar por estado</option>
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>

                        <button type="submit" class="perfil-btn">
                            Buscar
                        </button>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="perfil-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Tipo de clase</th>
                                <th>Matrícula</th>
                                <th>Sesiones</th>
                                <th>Precio</th>
                                <th>Modalidad</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var tarifa in Model)
                                {
                                    <tr>
                                        <td>
                                            TAR-@tarifa.IdTarifaClase.ToString("D3")
                                        </td>

                                        <td>
                                            @tarifa.Nombre
                                        </td>

                                        <td>
                                            @tarifa.TipoClase.Nombre
                                        </td>

                                        <td>
                                            @tarifa.CondicionMatricula
                                        </td>

                                        <td>
                                            @tarifa.CantidadLecciones
                                        </td>

                                        <td>
                                            $@tarifa.Precio.ToString("N2")
                                        </td>

                                        <td>
                                            @if (tarifa.CantidadLecciones == 1)
                                            {
                                                <span>Por sesión</span>
                                            }
                                            else
                                            {
                                                <span>Paquete</span>
                                            }

                                            @if (tarifa.PrecioPorPersona)
                                            {
                                                <small class="d-block text-muted">
                                                    Por persona
                                                </small>
                                            }
                                        </td>

                                        <td>
                                            @if (tarifa.Activa)
                                            {
                                                <span class="perfil-badge-success">
                                                    Activa
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="perfil-badge-warning">
                                                    Inactiva
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <a asp-controller="AdminTarifas"
                                               asp-action="Editar"
                                               asp-route-id="@tarifa.IdTarifaClase"
                                               class="perfil-action-link">
                                                Editar
                                            </a>

                                            <span class="perfil-action-separator">
                                                |
                                            </span>

                                            <form asp-controller="AdminTarifas"
                                                  asp-action="CambiarEstado"
                                                  method="post"
                                                  style="display:inline">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@tarifa.IdTarifaClase" />

                                                <button type="submit"
                                                        class="perfil-action-link"
                                                        style="background:none;
                                                    border:none;
                                                    padding:0;
                                                    cursor:pointer;">
                                                    @(tarifa.Activa ? "Desactivar" : "Activar")
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center">
                                        No hay tarifas registradas.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>