<script>
    function gamiTab(id) {
        ['puntos', 'niveles', 'recomp', 'ranking'].forEach(function (t) {
            document.getElementById('gpanel-' + t).style.display = t === id ? '' : 'none';
            var btn = document.getElementById('gtab-' + t);
            btn.style.borderBottomColor = t === id ? '#a5c422' : 'transparent';
            btn.style.color = t === id ? '#8eab1d' : '#757575';
        });
    }
</script>
