<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>@ViewData["Title"] - ProyectoGrupalTennis</title>

    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/css/animate.css" />
    <link rel="stylesheet" href="~/css/owl.carousel.css" />
    <link rel="stylesheet" href="~/css/owl.theme.default.min.css" />
    <link rel="stylesheet" href="~/css/tooplate-style.css" />
    <link rel="stylesheet" href="~/css/site.css?v=2" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        :root {
            --primary-color: #a5c422; /* Verde Tennis */
            --dark-bg: #121212;
            --card-bg: #1e1e1e;
            --text-main: #ffffff;
            --text-muted: #b0b0b0;
        }

        .main-footer {
            background-color: var(--dark-bg);
            color: var(--text-main);
            padding: 60px 0 30px 0;
            font-family: 'Montserrat', 'Segoe UI', Roboto, sans-serif;
        }

        .footer-thumb {
            margin-bottom: 30px; /* Separación en dispositivos móviles */
        }

        .footer-thumb h4 {
            color: var(--primary-color);
            text-transform: uppercase;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 1.5px;
            margin-bottom: 25px;
            text-align: left; /* Alineado a la izquierda */
        }

        .footer-info-text {
            color: var(--text-muted);
            font-size: 14px;
            line-height: 1.6;
            text-align: left; /* Alineado a la izquierda */
        }

        /* Contacto Unificado */
        .contact-list {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: flex-start; /* Alineado a la izquierda */
            gap: 15px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 14px;
            transition: 0.3s;
        }

        .contact-item:hover {
            color: var(--primary-color);
        }

        .icon-circle {
            width: 35px;
            height: 35px;
            background: var(--card-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-color);
            font-size: 14px;
            border: 1px solid #333;
        }

        /* Horarios */
        .hours-box {
            text-align: left;
            margin-top: 20px;
            font-size: 13px;
            color: var(--text-muted);
            border-top: 1px solid #2a2a2a;
            padding-top: 15px;
        }

        .hours-box span { color: #fff; font-weight: 600; }

        /* Redes Sociales Integradas en la columna */
        .social-container {
            display: flex;
            justify-content: flex-start;
            gap: 12px;
            margin-top: 20px;
        }

        .social-btn {
            width: 40px;
            height: 40px;
            background: var(--card-bg);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: 0.3s;
            text-decoration: none;
            border: 1px solid #333;
        }

        .social-btn:hover {
            background: var(--primary-color);
            color: #000;
            transform: translateY(-3px);
        }

        /* Mapa */
        .map-wrapper {
            border-radius: 12px;
            overflow: hidden;
            filter: grayscale(0.2);
            transition: 0.5s;
            border: 1px solid #333;
        }
        .map-wrapper:hover { filter: grayscale(0); }

        /* Footer Bottom Centrado y Balanceado */
        .footer-bottom {
            border-top: 1px solid #2a2a2a;
            padding-top: 25px;
            margin-top: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap; /* Para móviles */
        }

        .copyright {
            font-size: 13px;
            color: #777;
            margin: 0; /* Sin margen para alinear con el botón */
        }

        .btn-scroll-top {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: #222;
            color: var(--primary-color);
            border-radius: 50%;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-scroll-top:hover {
            background: var(--primary-color);
            color: #000;
        }
    </style>
</head>
<body id="top" data-spy="scroll" data-target=".navbar-collapse" data-offset="50">

    <!-- PRE LOADER -->
    <section class="preloader">
        <div class="spinner">
            <span class="spinner-rotate"></span>
        </div>
    </section>

    <!-- HEADER -->
    <header>
        <div class="container">
            <div class="row">
                <div class="col-md-4 col-sm-5">
                    <p>Tu academia de tennis</p>
                </div>
                <div class="col-md-8 col-sm-7 text-align-right">
                    <span class="phone-icon"><i class="fa fa-phone"></i> 010-060-0160</span>
                    <span class="date-icon"><i class="fa fa-calendar-plus-o"></i> 6:00 AM - 10:00 PM</span>
                    <span class="email-icon"><i class="fa fa-envelope-o"></i> <a href="#">info@company.com</a></span>
                </div>
            </div>
        </div>
    </header>

    <!-- MENU -->
    <section class="navbar navbar-default navbar-static-top" role="navigation">
        <div class="container">
            <div class="navbar-header">
                <button class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon icon-bar"></span>
                    <span class="icon icon-bar"></span>
                    <span class="icon icon-bar"></span>
                </button>
                <a href="/" class="navbar-brand"><i class="fa fa-h-square"></i>cademia de Tennis</a>
            </div>
            <div class="collapse navbar-collapse">
                <ul class="nav navbar-nav navbar-right">
                    <li><a href="/#top" class="smoothScroll">Home</a></li>
                    <li><a href="/#about" class="smoothScroll">About Us</a></li>
                    <li><a href="/#team" class="smoothScroll">Clases</a></li>
                    <li><a href="/#news" class="smoothScroll">News</a></li>
                    <li><a href="/#google-map" class="smoothScroll">Contact</a></li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle nav-link text-dark" data-toggle="dropdown">
                            <i class="fa fa-th-large"></i> Módulos <span class="caret"></span></a>
                        <ul class="dropdown-menu">

                            <li><a asp-controller="Home" asp-action="PerfilAdmin"> <i class="fa fa-user-shield"></i> Perfil Administrador</a></li>
                            <li><a asp-controller="Home" asp-action="PerfilUsuario"> <i class="fa fa-user-shield"></i> Perfil Usuario</a></li>
                            <li><a asp-controller="Home" asp-action="Gamificacion"><i class="fa fa-gamepad"></i> Gamificación</a></li>
                            <li><a asp-controller="Home" asp-action="Geolocalizacion"><i class="fa fa-map-marker-alt"></i> Geolocalización</a></li>
                            <li><a asp-controller="Home" asp-action="Matricula"><i class="fa fa-file-signature"></i> Matrícula</a></li>
                            <li><a asp-controller="Home" asp-action="Dashboard"><i class="fa fa-chart-line"></i> Dashboard y Reportes</a></li>
                            <li><a asp-controller="Home" asp-action="Notificaciones"><i class="fa fa-bell"></i> Notificaciones</a></li>
                            <li><a asp-controller="Home" asp-action="Feedback"><i class="fa fa-comments"></i> Feedback y Encuestas</a></li>
                            <li><a asp-controller="Home" asp-action="Progreso"><i class="fa fa-chart-bar"></i> Progreso Técnico</a></li>
                        </ul>
                    </li>
                    <li class="appointment-btn">
                        <a href="/#appointment">Agendar una cita</a>
                    </li>

                    <li class="appointment-btn">
                        <a asp-controller="Home" asp-action="Login">Iniciar Sesión</a>
                    </li>

                    <li class="appointment-btn">
                        <a asp-controller="Home" asp-action="Registro">Registrarse</a>
                    </li>

                </ul>
            </div>
        </div>
    </section>

    @RenderBody()

    <!-- FOOTER -->
	<footer class="main-footer">
		<div class="container">
			<div class="row">
				<div class="col-md-4 col-sm-6">
					<div class="footer-thumb">
						<h4>Nuestra Academia</h4>
						<p class="footer-info-text">
							Pasión por el tennis en cada entrenamiento. Instalaciones profesionales en el corazón de San José para todos los niveles.
						</p>
						<div class="social-container">
							<a href="https://www.facebook.com/tenismmp" class="social-btn">
								<i class="fab fa-facebook-f"></i>
							</a>
							<a href="#" class="social-btn">
								<i class="fab fa-instagram"></i>
							</a>
							<a href="https://wa.me/50683764752" class="social-btn">
								<i class="fab fa-whatsapp"></i>
							</a>
							<a href="https://x.com/mariomunozp" class="social-btn">
								<i class="fab fa-x-twitter"></i>
							</a>
						</div>
					</div>
				</div>

				<div class="col-md-4 col-sm-6">
					<div class="footer-thumb">
						<h4>Contacto & Horario</h4>
						<div class="contact-list">
							<a href="tel:+50622839369" class="contact-item">
								<div class="icon-circle">
									<i class="fa fa-phone"></i>
								</div>
								(506) 2283-9369
							</a>
							<a href="https://wa.me/50683764752" class="contact-item">
								<div class="icon-circle">
									<i class="fab fa-whatsapp"></i>
								</div>
								(506) 8376-4752
							</a>
							<a href="mailto:info@tenismmp.com" class="contact-item">
								<div class="icon-circle">
									<i class="fa fa-envelope"></i>
								</div>
								info@tenismmp.com
							</a>
						</div>
						<div class="hours-box">
							<p>
								Lunes - Sábado: <span>6:00 AM - 11:00 PM</span><br />
								Domingo: <span>6:00 AM - 12:00 MD</span>
							</p>
						</div>
					</div>
				</div>

				<div class="col-md-4 col-sm-12">
					<div class="footer-thumb">
						<h4>Ubicación</h4>
						<div class="map-wrapper">
							<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3930.1906940445497!2d-84.06010078470023!3d9.918070577159687!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e39fc33e177b%3A0x51f513e80d90af60!2sAcademia+de+Tenis+M.M.P.!5e0!3m2!1ses-419!2scr!4v1446309209705"
									width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
						</div>
						<p class="mt-2 small" style="color: #666; text-align: left;">
							<br /><i class="fa fa-map-marker-alt" style="color: var(--primary-color);"></i> San José, Costa Rica.
						</p>
					</div>
				</div>
			</div>

			<div class="footer-bottom">
				<p class="copyright">
					© 2026 <strong>Tenis M.M.P</strong> | Academia de Tenis.
				</p>
				<a href="#top" class="smoothScroll btn-scroll-top">
					<i class="fa fa-chevron-up"></i>
				</a>
			</div>
		</div>
	</footer>

    <script src="~/js/jquery.js"></script>
    <script src="~/js/bootstrap.min.js"></script>
    <script src="~/js/jquery.sticky.js"></script>
    <script src="~/js/jquery.stellar.min.js"></script>
    <script src="~/js/wow.min.js"></script>
    <script src="~/js/smoothscroll.js"></script>
    <script src="~/js/owl.carousel.min.js"></script>
    <script src="~/js/custom.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>