@model ProyectoGrupalTennis.Models.CambiarPasswordViewModel

@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h2 style="margin-bottom:50px;">
                Cambiar contraseña
            </h2>

            <div id="mensajeCambioPassword" class="mb-4"></div>

            <form id="formCambiarPassword"
                  asp-action="CambiarPassword"
                  method="post">

                @Html.AntiForgeryToken()

                <div style="margin-bottom:35px;">
                    <label asp-for="PasswordActual"
                           style="display:block; margin-bottom:12px; font-weight:bold;">
                    </label>

                    <div style="position:relative; width:100%;">
                        <input asp-for="PasswordActual"
                               type="password"
                               class="form-control"
                               id="PasswordActual"
                               style="padding-right:45px;" />

                        <i class="fa fa-eye"
                           title="Mostrar/Ocultar contraseña"
                           onclick="togglePassword('PasswordActual', this)"
                           style="position:absolute; right:15px; top:50%; transform:translateY(-50%); cursor:pointer; color:#777;">
                        </i>
                    </div>
                </div>

                <div style="margin-bottom:35px;">
                    <label asp-for="NuevaPassword"
                           style="display:block; margin-bottom:12px; font-weight:bold;">
                    </label>

                    <div style="position:relative; width:100%;">
                        <input asp-for="NuevaPassword"
                               type="password"
                               class="form-control"
                               id="NuevaPassword"
                               style="padding-right:45px;" />

                        <i class="fa fa-eye"
                           title="Mostrar/Ocultar contraseña"
                           onclick="togglePassword('NuevaPassword', this)"
                           style="position:absolute; right:15px; top:50%; transform:translateY(-50%); cursor:pointer; color:#777;">
                        </i>
                    </div>
                </div>

                <div style="margin-bottom:50px;">
                    <label asp-for="ConfirmarPassword"
                           style="display:block; margin-bottom:12px; font-weight:bold;">
                    </label>

                    <div style="position:relative; width:100%;">
                        <input asp-for="ConfirmarPassword"
                               type="password"
                               class="form-control"
                               id="ConfirmarPassword"
                               style="padding-right:45px;" />

                        <i class="fa fa-eye"
                           title="Mostrar/Ocultar contraseña"
                           onclick="togglePassword('ConfirmarPassword', this)"
                           style="position:absolute; right:15px; top:50%; transform:translateY(-50%); cursor:pointer; color:#777;">
                        </i>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Cambiar contraseña
                </button>

                <a asp-controller="Home"
                   asp-action="PerfilUsuario"
                   class="btn btn-danger">
                    Cancelar
                </a>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePassword(inputId, icon) {
            const input = document.getElementById(inputId);

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }

        document.getElementById("formCambiarPassword").addEventListener("submit", async function (e) {
            e.preventDefault();

            const mensaje = document.getElementById("mensajeCambioPassword");
            mensaje.innerHTML = "";

            const actual = document.getElementById("PasswordActual").value;
            const nueva = document.getElementById("NuevaPassword").value;
            const confirmar = document.getElementById("ConfirmarPassword").value;

            if (!actual || !nueva || !confirmar) {
                mensaje.innerHTML = '<div class="text-danger"><ul><li>Debe completar todos los campos.</li></ul></div>';
                return;
            }

            if (nueva.length < 8) {
                mensaje.innerHTML = '<div class="text-danger"><ul><li>La nueva contraseña debe tener al menos 8 caracteres.</li></ul></div>';
                return;
            }

            if (!/\d/.test(nueva)) {
                mensaje.innerHTML = '<div class="text-danger"><ul><li>La nueva contraseña debe contener al menos un número.</li></ul></div>';
                return;
            }

            if (nueva !== confirmar) {
                mensaje.innerHTML = '<div class="text-danger"><ul><li>La nueva contraseña y la confirmación no coinciden.</li></ul></div>';
                return;
            }

            const form = e.target;
            const formData = new FormData(form);

            const response = await fetch(form.action, {
                method: "POST",
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                mensaje.innerHTML = `<div class="alert alert-success">${result.message}</div>`;
                form.reset();
            } else {
                mensaje.innerHTML = `<div class="text-danger"><ul><li>${result.message}</li></ul></div>`;
            }
        });
    </script>
}