@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar contraseña</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>

<body class="auth-page">
    <div class="auth-wrapper">
        <div class="card auth-card">
            <div class="row g-0">

                <!-- LADO VERDE -->
                <div class="col-lg-5">
                    <div class="auth-left">
                        <a href="/Home/Index" class="badge-custom">
                            Academia de Tennis
                        </a>

                        <h1>¿Olvidaste tu contraseña?</h1>

                        <p>
                            Ingresa tu correo electrónico y te enviaremos las instrucciones
                            para restablecer tu contraseña.
                        </p>
                    </div>
                </div>

                <!-- LADO FORM -->
                <div class="col-lg-7">
                    <div class="auth-right">

                        <h2 class="brand-title">Recuperar contraseña</h2>
                        <p class="brand-subtitle">
                            Escribe el correo asociado a tu cuenta
                        </p>

                        <form class="auth-form">

                            <div class="mb-3">
                                <label class="form-label">Correo electrónico</label>
                                <input type="email" class="form-control" placeholder="ejemplo@correo.com" />
                            </div>

                            <div class="d-grid auth-actions">
                                <button class="btn btn-login">
                                    Enviar nueva contraseña
                                </button>
                            </div>

                            <div class="text-center mt-3">
                                <span class="text-muted">¿Recordaste tu contraseña? </span>
                                <a href="/Home/Login" class="helper-link">Iniciar sesión</a>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>