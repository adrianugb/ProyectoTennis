@{
    ViewData["Title"] = "Registro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - Academia de Tennis</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-wrapper">
        <div class="card auth-card">
            <div class="row g-0">
                <div class="col-lg-5">
                    <div class="auth-left">
                        <a href="/Home/Index" class="badge-custom">
                            Academia de Tennis
                        </a>

                        <h1>Bienvenido</h1>
                        <p>
                            Regístrate para acceder a tu plataforma y gestionar clases, pagos,
                            alumnos, profesores y procesos administrativos de forma rápida y sencilla.
                        </p>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="auth-right">
                        <h2 class="brand-title">Registrarme</h2>
                        <p class="brand-subtitle">
                            Regístrate para continuar
                        </p>

                        <form class="auth-form">
                            <div class="mb-3">
                                <label for="correo" class="form-label">Correo electrónico</label>
                                <input type="email" class="form-control" id="correo" placeholder="ejemplo@correo.com" />
                            </div>

                            <div class="mb-3">
                                <label for="contrasena" class="form-label">Contraseña</label>
                                <input type="password" class="form-control" id="contrasena" placeholder="Ingresa tu contraseña" />
                            </div>

                            <div class="mb-3">
                                <label for="confirmarContrasena" class="form-label">Confirmar contraseña</label>
                                <input type="password" class="form-control" id="confirmarContrasena" placeholder="Confirma tu contraseña" />
                            </div>

                            <div class="auth-inline">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="recordarme" />
                                    <label class="form-check-label" for="recordarme">
                                        Recordarme
                                    </label>
                                </div>

                                <a href="/Home/Login" class="helper-link">¿Ya tienes una sesión?</a>
                            </div>

                            <div class="d-grid auth-actions">
                                <a href="/Home/Dashboard" class="btn btn-login">Registrarme</a>
                            </div>
                        </form>

                        <p class="footer-text"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>