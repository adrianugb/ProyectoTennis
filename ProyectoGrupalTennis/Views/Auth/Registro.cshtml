@model ProyectoGrupalTennis.Models.RegisterViewModel

@{
    ViewData["Title"] = "Registro";
    Layout = null;
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - Academia de Tennis</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-wrapper">
        <div class="card auth-card">
            <div class="row g-0">
                <div class="col-lg-5">
                    <div class="auth-left">
                        <a href="/Home/Index" class="badge-custom">
                            Academia de Tennis
                        </a>

                        <h1>Bienvenido</h1>
                        <p>
                            Regístrate para acceder a tu plataforma y gestionar clases, pagos,
                            alumnos, profesores y procesos administrativos de forma rápida y sencilla.
                        </p>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="auth-right">
                        <h2 class="brand-title">Registrarme</h2>
                        <p class="brand-subtitle">
                            Regístrate para continuar
                        </p>

                        <form asp-controller="Auth" asp-action="Registro" method="post" class="auth-form">

                            <div class="mb-3">
                                <label asp-for="Nombre" class="form-label"></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ingresa tu nombre" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Apellido" class="form-label"></label>
                                <input asp-for="Apellido" class="form-control" placeholder="Ingresa tu apellido" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>


                            <div class="mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" class="form-control" placeholder="Ingresa tu contraseña" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ConfirmPassword" class="form-label"></label>
                                <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirma tu contraseña" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="auth-inline">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="recordarme" />
                                    <label class="form-check-label" for="recordarme">
                                        Recordarme
                                    </label>
                                </div>

                                <a href="/Home/Login" class="helper-link">¿Ya tienes cuenta?</a>
                            </div>

                            <div class="d-grid auth-actions">
                                <button type="submit" class="btn btn-login">
                                    Registrarme
                                </button>
                            </div>
                        </form>

                        <p class="footer-text"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>