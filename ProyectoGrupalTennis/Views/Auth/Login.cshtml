@model ProyectoGrupalTennis.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Academia de Tennis</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-wrapper">
        <div class="card auth-card">
            <div class="row g-0">
                <div class="col-lg-5">
                    <div class="auth-left">
                        <a href="/Home/Index" class="badge-custom">
                            Academia de Tennis
                        </a>

                        <h1>Bienvenido de nuevo</h1>

                        <p>
                            Accede a tu plataforma para gestionar clases, pagos, alumnos,
                            profesores y procesos administrativos de forma rápida y sencilla.
                        </p>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="auth-right">
                        <h2 class="brand-title">Iniciar Sesión</h2>
                        <p class="brand-subtitle">
                            Ingresa tus credenciales para continuar
                        </p>
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>  @* //Eso mostrara errores generales del login *@

                        <form asp-controller="Auth" asp-action="Login" method="post" class="auth-form">
                            <div class="mb-3">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label"></label>
                                <input asp-for="Password" class="form-control" placeholder="Ingresa tu contraseña" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="auth-inline">
                                <div class="form-check">
                                    <input asp-for="Recordarme" class="form-check-input" />
                                    <label asp-for="Recordarme" class="form-check-label">
                                        Recordarme
                                    </label>
                                </div>


                                <a href="/Home/RecuperarContrasena" class="helper-link">¿Olvidaste tu contraseña?</a>
                            </div>

                            <div class="d-grid auth-actions">
                                <button type="submit" class="btn btn-login">
                                    Iniciar sesión
                                </button>
                            </div>

                            <div class="text-center">
                                <span class="text-muted">¿No tienes cuenta? </span>
                                <a href="/Home/Registro" class="helper-link">Crear cuenta</a>
                            </div>

                            <a href="/Home/PerfilAdmin">Entrar como Admin</a>
                            <a href="/Home/PerfilUsuario">Entrar como Usuario</a>
                        </form>

                        <p class="footer-text"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>