@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Academia de Tennis</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>
            body {
                margin: 0;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                min-height: 100vh;
                background:
                    linear-gradient(rgba(8, 24, 45, 0.75), rgba(8, 24, 45, 0.82)),
                    url('https://images.unsplash.com/photo-1554068865-24cecd4e34b8?auto=format&fit=crop&w=1600&q=80');
                background-size: cover;
                background-position: center;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .badge-custom:hover {
    background-color: rgba(255,255,255,0.3);
    cursor: pointer;
} 
            .login-wrapper {
                width: 100%;
                max-width: 1100px;
                margin: 30px;
            }

            .login-card {
                border: none;
                border-radius: 24px;
                overflow: hidden;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
            }

            .login-left {
                background: linear-gradient(135deg, #7cb518, #55a630);
                color: white;
                padding: 60px 45px;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .login-left h1 {
                font-size: 2.5rem;
                font-weight: 800;
                margin-bottom: 18px;
            }

            .login-left p {
                font-size: 1rem;
                line-height: 1.7;
                margin-bottom: 0;
                opacity: 0.95;
            }

            .badge-custom {
                display: inline-block;
                background-color: rgba(255,255,255,0.18);
                border: 1px solid rgba(255,255,255,0.25);
                padding: 8px 14px;
                border-radius: 999px;
                font-size: 0.9rem;
                margin-bottom: 22px;
                width: fit-content;
            }

            .login-right {
                background-color: #ffffff;
                padding: 55px 45px;
            }

            .brand-title {
                font-size: 2rem;
                font-weight: 800;
                color: #1f2937;
                margin-bottom: 8px;
            }

            .brand-subtitle {
                color: #6b7280;
                margin-bottom: 30px;
            }

            .form-label {
                font-weight: 600;
                color: #374151;
            }

            .form-control {
                border-radius: 12px;
                padding: 12px 14px;
                border: 1px solid #d1d5db;
            }

            .form-control:focus {
                border-color: #7cb518;
                box-shadow: 0 0 0 0.2rem rgba(124, 181, 24, 0.2);
            }

            .btn-login {
                background-color: #7cb518;
                border: none;
                border-radius: 12px;
                padding: 12px;
                font-weight: 700;
                font-size: 1rem;
            }

            .btn-login:hover {
                background-color: #6aa112;
            }

            .helper-link {
                color: #55a630;
                text-decoration: none;
                font-weight: 600;
            }

            .helper-link:hover {
                text-decoration: underline;
            }

            .footer-text {
                text-align: center;
                margin-top: 22px;
                color: #6b7280;
            }

            @@media (max-width: 991px) {
                .login-left {
                    display: none;
                }

                .login-right {
                    padding: 40px 28px;
                }

                .login-wrapper {
                    margin: 16px;
                }
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="card login-card">
            <div class="row g-0">
                <div class="col-lg-5">
                    <div class="login-left">
                        <a href="/Home/Index" class="badge-custom text-white text-decoration-none">
                            Academia de Tennis
                        </a>                        <h1>Bienvenido de nuevo</h1>
                        <p>
                            Accede a tu plataforma para gestionar clases, pagos, alumnos,
                            profesores y procesos administrativos de forma rápida y sencilla.
                        </p>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="login-right">
                        <h2 class="brand-title">Iniciar Sesión</h2>
                        <p class="brand-subtitle">
                            Ingresa tus credenciales para continuar
                        </p>

                        <form>
                            <div class="mb-3">
                                <label for="correo" class="form-label">Correo electrónico</label>
                                <input type="email" class="form-control" id="correo" placeholder="ejemplo@correo.com" />
                            </div>

                            <div class="mb-3">
                                <label for="contrasena" class="form-label">Contraseña</label>
                                <input type="password" class="form-control" id="contrasena" placeholder="Ingresa tu contraseña" />
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="recordarme" />
                                    <label class="form-check-label" for="recordarme">
                                        Recordarme
                                    </label>
                                </div>

                                <a href="/Home/RecuperarContrasena" class="helper-link">¿Olvidaste tu contraseña?</a>
                            </div>

                            <div class="d-grid mb-3">
                                <a href="/Home/Dashboard" class="btn btn-login text-white">Iniciar sesión</a>
                            </div>

                            <div class="text-center">
                                <span class="text-muted">¿No tienes cuenta? </span>
                                <a href="/Home/Registro" class="helper-link">Crear cuenta</a>
                            </div>
                        </form>

                        <p class="footer-text">
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>